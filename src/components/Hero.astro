---
interface Action {
  href: string;
  label: string;
  primary?: boolean;
}

interface Props {
  title: string;
  catchcopy: string;
  description: string;
  actions?: Action[];
}

const { title, catchcopy, description, actions = [] } = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 py-10 sm:py-14">
  <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-zinc-950 via-purple-950/60 to-black p-6 shadow-2xl sm:p-10">
    <p class="mb-3 text-sm font-semibold tracking-[0.25em] text-fuchsia-300">
      Visual Kei Live Trip Guide
    </p>

    <h1 class="text-3xl font-black leading-tight text-white sm:text-5xl">
      {title}
    </h1>

    <p class="mt-4 text-lg font-semibold text-fuchsia-100">
      {catchcopy}
    </p>

    <p class="mt-4 max-w-3xl text-sm leading-7 text-zinc-200 sm:text-base">
      {description}
    </p>

    {actions.length > 0 && (
      <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        {actions.map((action) => (
          <a
            href={action.href}
            class:list={[
              "inline-flex min-h-11 items-center justify-center rounded-full px-5 py-3 text-sm font-bold transition",
              action.primary
                ? "bg-fuchsia-500 text-white hover:bg-fuchsia-400"
                : "border border-white/15 bg-white/5 text-white hover:bg-white/10"
            ]}
          >
            {action.label}
          </a>
        ))}
      </div>
    )}

    <div class="mt-8 rounded-2xl border border-white/10 bg-black/35 p-4">
      <h2 class="text-base font-bold text-white">
        遠征前チェック
      </h2>
      <ul class="mt-3 grid gap-2 text-sm text-zinc-200 sm:grid-cols-3">
        <li>公式チケット情報を確認</li>
        <li>会場・駅・ロッカーを確認</li>
        <li>終電と宿泊ラインを確認</li>
      </ul>
    </div>
  </div>
</section>
