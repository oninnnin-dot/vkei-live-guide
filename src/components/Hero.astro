---
interface Action {
  href: string;
  label: string;
  primary?: boolean;
}

interface Props {
  title: string;
  catchcopy: string;
  description: string;
  actions?: Action[];
}

const { title, catchcopy, description, actions = [] } = Astro.props;
---

<section class="relative overflow-hidden border-b border-amber/20 bg-black/20">
  <div class="container-navi grid gap-8 py-10 md:grid-cols-[1fr_0.72fr] md:py-16">
    <div class="flex flex-col justify-center">
      <p class="gothic-label">Oshikatsu Trip Guide</p>
      <h1 class="font-classical mt-4 max-w-full text-3xl font-black leading-tight text-mist sm:text-4xl md:text-6xl">{title}</h1>
      <p class="mt-5 max-w-full text-lg font-black leading-relaxed text-mist sm:text-xl md:text-2xl">{catchcopy}</p>
      <p class="mt-4 max-w-2xl text-base leading-8 text-muted">{description}</p>
      {actions.length > 0 && (
        <div class="mt-7 flex flex-col gap-3 md:grid md:grid-cols-2">
          {
            actions.map((action) => (
              <a
                class={`focus-ring inline-flex min-h-12 w-full items-center justify-center rounded-md px-5 py-3 text-center text-sm font-black leading-snug transition ${
                  action.primary
                    ? 'gothic-button'
                    : 'gothic-button-secondary'
                }`}
                href={action.href}
              >
                {action.label}
              </a>
            ))
          }
        </div>
      )}
    </div>
    <div class="gothic-panel min-h-72 rounded-xl p-5">
      <div class="flex h-full flex-col justify-between gap-5">
        <div class="grid grid-cols-5 gap-2 pt-3" aria-hidden="true">
          <span class="h-32 rounded-sm border border-amber/20 bg-violet/70"></span>
          <span class="mt-8 h-24 rounded-sm border border-amber/20 bg-[#120914]"></span>
          <span class="h-40 rounded-sm border border-amber/35 bg-amber/70"></span>
          <span class="mt-12 h-20 rounded-sm border border-amber/20 bg-[#0b1020]"></span>
          <span class="mt-4 h-28 rounded-sm border border-amber/20 bg-[#2a0710]"></span>
        </div>
        <div class="rounded-md border border-amber/25 bg-black/35 p-4">
          <p class="font-classical text-sm font-black text-mist">遠征前チェック</p>
          <ul class="mt-3 space-y-2 text-sm text-muted">
            <li>公式チケット情報を確認</li>
            <li>会場・駅・ロッカーを確認</li>
            <li>終電と宿泊ラインを確認</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
