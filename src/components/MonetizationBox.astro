---
interface Item {
  title: string;
  text: string;
  links?: Array<{
    label: string;
    url: string;
  }>;
}

interface Props {
  title?: string;
  lead?: string;
  items?: Item[];
}

const amazonAffiliateTag = 'AFFILIATE_ID';
const amazonSearchUrl = (keyword: string) =>
  `https://www.amazon.co.jp/s?k=${encodeURIComponent(keyword)}&tag=${amazonAffiliateTag}`;
const rakutenAffiliateId = 'AFFILIATE_ID';
const rakutenSearchUrl = (keyword: string) =>
  `https://search.rakuten.co.jp/search/mall/${encodeURIComponent(keyword)}/?scid=af_pc_etc&rafct=i_${rakutenAffiliateId}`;
const yahooAffiliateId = 'AFFILIATE_ID';
const yahooSearchUrl = (keyword: string) =>
  `https://shopping.yahoo.co.jp/search?p=${encodeURIComponent(keyword)}&fr=affi&aff_id=${yahooAffiliateId}`;

const {
  title = '遠征前に用意しておくと安心なもの',
  lead = '物販・雨・終演後移動がある日は、荷物を減らしつつ必要なものだけ持つのがおすすめです。',
  items = [
    {
      title: '電池切れ対策',
      text: '電子チケット、地図、終電確認を使う日は、軽いモバイルバッテリーと短いケーブルを先に入れておくと安心です。',
      links: [
        { label: 'Amazonでモバイルバッテリーを探す', url: amazonSearchUrl('モバイルバッテリー 軽量') },
        { label: '楽天でモバイルバッテリーを探す', url: rakutenSearchUrl('モバイルバッテリー 軽量') },
        { label: 'YahooでUSB-Cケーブルを探す', url: yahooSearchUrl('USB-Cケーブル 短い') },
      ],
    },
    {
      title: '雨と荷物増え対策',
      text: '雨の日や物販後は、折りたたみ傘、圧縮袋、小さめショルダーを先に用意しておくと移動が楽です。',
      links: [
        { label: '軽量折りたたみ傘', url: amazonSearchUrl('軽量折りたたみ傘') },
        { label: '衣類圧縮袋', url: rakutenSearchUrl('衣類圧縮袋') },
        { label: '小さめショルダーバッグ', url: yahooSearchUrl('小さめ ショルダーバッグ') },
      ],
    },
    {
      title: 'チケットと視界対策',
      text: '紙チケットや身分証をまとめるケース、ホールや後方席用の双眼鏡があると当日の探し物を減らせます。',
      links: [
        { label: 'チケットホルダー', url: amazonSearchUrl('チケットホルダー') },
        { label: '双眼鏡 ライブ用', url: rakutenSearchUrl('双眼鏡 ライブ用') },
        { label: '身分証ケース', url: yahooSearchUrl('身分証ケース') },
      ],
    },
    {
      title: '音と移動疲れ対策',
      text: '小規模ライブハウスや長距離移動の日は、耳栓や薄手ポーチで体力を残しやすくします。',
      links: [
        { label: 'ライブ用耳栓', url: amazonSearchUrl('ライブ用 耳栓') },
        { label: '薄型トラベルポーチ', url: rakutenSearchUrl('薄型 トラベルポーチ') },
        { label: '折りたたみサブバッグ', url: yahooSearchUrl('折りたたみ サブバッグ') },
      ],
    },
  ],
} = Astro.props;
---

<aside class="gothic-card rounded-xl p-5 md:p-6">
  <p class="gothic-label">Preparation</p>
  <h2 class="font-classical mt-2 text-2xl font-black leading-tight text-mist">{title}</h2>
  <p class="mt-3 text-sm leading-7 text-muted">{lead}</p>
  <div class="mt-5 grid gap-3 md:grid-cols-2">
    {items.map((item) => (
      <div class="rounded-md border border-amber/20 bg-black/25 p-4">
        <p class="font-classical font-black text-mist">{item.title}</p>
        <p class="mt-2 text-sm leading-7 text-muted">{item.text}</p>
        {item.links && item.links.length > 0 && (
          <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-muted">
            {item.links.map((link) => (
              <li>
                <a class="text-amber underline decoration-amber/40 underline-offset-4 transition hover:text-mist" href={link.url} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>
  <p class="mt-4 text-xs leading-6 text-muted">
    このセクションにはアフィリエイトリンクが含まれます。商品は実用性を優先して選定しており、購入により当サイトに報酬が入る場合があります。
  </p>
</aside>
