---
import affiliateLinks from '@data/links.json';

interface Item {
  title: string;
  text: string;
  links?: Array<{
    label: string;
    url: string;
    cta?: string;
    imageUrl?: string;
    impressionUrl?: string;
    rel?: string;
    referrerPolicy?: string;
  }>;
}

interface BannerLink {
  label: string;
  url: string;
  imageUrl: string;
  alt: string;
  rel?: string;
  referrerPolicy?: string;
}

interface Props {
  title?: string;
  lead?: string;
  items?: Item[];
  banner?: BannerLink | false | null;
}

const productLinks = affiliateLinks.products;
const defaultBanner = affiliateLinks.banners.rakutenMarket;
const rakutenSearchUrl = (keyword: string) =>
  affiliateLinks.rakuten.searchUrlTemplate.replace(
    '{RAKUTEN_SEARCH_URL}',
    encodeURIComponent(`https://search.rakuten.co.jp/search/mall/${keyword}/`)
  );
const rakutenSearchLink = (label: string, keyword = label, cta = '楽天で探す') => ({
  label,
  cta,
  url: rakutenSearchUrl(keyword),
  rel: 'nofollow sponsored noopener',
  referrerPolicy: 'no-referrer-when-downgrade',
});

const {
  title = '遠征前に用意しておくと安心なもの',
  lead = 'アフィリエイトリンクを含みます。電子チケット、地図、交通検索、終演後の連絡など、ライブ当日はスマホや天候まわりの準備が大事です。必要なものだけ事前にそろえておくと、当日の不安を減らせます。',
  banner = defaultBanner,
  items = [
    {
      title: 'スマホ電池対策',
      text: '電子チケット、地図、交通検索、終演後の連絡でスマホの電池を使いがちです。遠征や終演が遅い日は、薄型のモバイルバッテリーや充電ケーブルを用意しておくと安心です。',
      links: [
        { ...productLinks.mobileBattery, cta: '楽天で見る' },
        { ...productLinks.usbCable, cta: '楽天で見る' },
        rakutenSearchLink('ケーブル内蔵モバイルバッテリー', 'ケーブル内蔵 モバイルバッテリー', '楽天で探す'),
      ],
    },
    {
      title: '雨の日・整列対策',
      text: '雨の日は、駅から会場までの移動や整列で靴や荷物が濡れやすくなります。軽い晴雨兼用傘や靴用防水グッズがあると、終演後まで動きやすくなります。',
      links: [
        { ...productLinks.foldingUmbrella, cta: '楽天で見る' },
        rakutenSearchLink('靴用防水スプレー', '靴 防水スプレー', '楽天で探す'),
        rakutenSearchLink('レインシューズカバー', 'レインシューズカバー', '楽天で探す'),
      ],
    },
    {
      title: '身だしなみ・体調対策',
      text: '地下ライブハウスや整列では、暑さ・寒さ・湿気で体力を削られやすいです。季節に合わせて汗拭きシート、冷却シート、カイロを用意しておくと安心です。',
      links: [
        rakutenSearchLink('汗拭きシート', '汗拭きシート', '楽天で探す'),
        rakutenSearchLink('制汗シート', '制汗シート', '楽天で探す'),
        rakutenSearchLink('冷却シート', '冷却シート', '楽天で探す'),
        rakutenSearchLink('使い捨てカイロ', '使い捨てカイロ', '楽天で探す'),
      ],
    },
    {
      title: '音量が不安な人向け',
      text: '小規模ライブハウスでは、スピーカーに近い位置になることがあります。音量が不安な人や、終演後の耳鳴りが気になりやすい人は、ライブ用耳栓を用意しておくと安心です。',
      links: [
        { ...productLinks.earplugs, cta: '楽天で見る' },
        rakutenSearchLink('音楽用イヤープラグ', '音楽用 イヤープラグ', '楽天で探す'),
      ],
    },
    {
      title: '遠征荷物対策',
      text: '遠征や物販の日は、着替えや購入品で荷物が増えやすくなります。衣類圧縮袋やトラベルポーチがあると、バッグの中を整理しやすくなります。',
      links: [
        { ...productLinks.compressionBags, cta: '楽天で見る' },
        { ...productLinks.travelPouch, cta: '楽天で見る' },
      ],
    },
  ],
} = Astro.props;
---

<aside class="gothic-card rounded-xl p-5 md:p-6">
  <p class="gothic-label">Preparation</p>
  <h2 class="font-classical mt-2 text-2xl font-black leading-tight text-mist">{title}</h2>
  <p class="mt-3 text-sm leading-7 text-muted">{lead}</p>
  <div class="mt-5 grid gap-3 md:grid-cols-2">
    {items.map((item) => (
      <div class="rounded-md border border-amber/20 bg-black/25 p-4">
        <p class="font-classical font-black text-mist">{item.title}</p>
        <p class="mt-2 text-sm leading-7 text-muted">{item.text}</p>
        {item.links && item.links.length > 0 && (
          <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-muted">
            {item.links.map((link) => (
              <li>
                <a
                  class={`inline-flex gap-3 text-amber underline decoration-amber/40 underline-offset-4 transition hover:text-mist ${link.imageUrl ? 'items-center' : ''}`}
                  href={link.url}
                  target="_blank"
                  rel={link.rel ?? 'nofollow sponsored noopener'}
                  referrerpolicy={link.referrerPolicy ?? 'no-referrer-when-downgrade'}
                >
                  {link.imageUrl && (
                    <img class="size-12 rounded-md border border-amber/20 object-cover" src={link.imageUrl} alt={link.label} loading="lazy" />
                  )}
                  <span class="grid gap-0.5">
                    <span class="text-mist">{link.label}</span>
                    <span>{link.cta ?? '楽天で見る'}</span>
                  </span>
                </a>
                {link.impressionUrl && <img src={link.impressionUrl} alt="" loading="lazy" width="1" height="1" style="border: 0px;" />}
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>
  {banner && (
    <div class="mt-5 rounded-md border border-amber/20 bg-black/20 p-4">
      <div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-center">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.18em] text-amber/80">広告</p>
          <h3 class="font-classical mt-2 text-lg font-black leading-tight text-mist">楽天市場で遠征準備アイテムを探す</h3>
          <p class="mt-2 text-sm leading-7 text-muted">
            電子チケット、地図、交通検索、終演後の連絡など、ライブ当日はスマホや小物まわりの準備が大事です。楽天市場で、遠征やライブ前後に役立つ持ち物を探せます。
          </p>
        </div>
        <a
          class="focus-ring inline-flex justify-center rounded-md border border-amber/20 bg-black/30 p-2 transition hover:border-amber/50"
          href={banner.url}
          target="_blank"
          rel={banner.rel ?? 'nofollow sponsored noopener'}
          referrerpolicy={banner.referrerPolicy ?? 'no-referrer-when-downgrade'}
          aria-label={banner.label}
        >
          <img class="max-h-28 w-auto rounded-sm object-contain" src={banner.imageUrl} alt={banner.alt} loading="lazy" />
        </a>
      </div>
    </div>
  )}
  <p class="mt-4 text-xs leading-6 text-muted">
    このセクションにはアフィリエイトリンクを含みます。商品は実用性を優先して選定しており、購入により当サイトに報酬が入る場合があります。
  </p>
</aside>
