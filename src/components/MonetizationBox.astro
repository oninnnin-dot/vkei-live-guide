---
interface Item {
  title: string;
  text: string;
  links?: Array<{
    label: string;
    url: string;
  }>;
}

interface Props {
  title?: string;
  lead?: string;
  items?: Item[];
}

const amazonAffiliateTag = 'AFFILIATE_ID';
const amazonSearchUrl = (keyword: string) =>
  `https://www.amazon.co.jp/s?k=${encodeURIComponent(keyword)}&tag=${amazonAffiliateTag}`;

const {
  title = '遠征前に用意しておくと安心なもの',
  lead = '物販・雨・終演後移動がある日は、荷物を減らしつつ必要なものだけ持つのがおすすめです。',
  items = [
    {
      title: '持ち物おすすめ枠',
      text: 'チケット、身分証、現金、IC、モバイルバッテリー、雨具を小さくまとめる前提で準備します。',
      links: [
        { label: 'ミニ財布', url: amazonSearchUrl('ミニ財布') },
        { label: 'スマホショルダーストラップ', url: amazonSearchUrl('スマホショルダーストラップ') },
        { label: '小型コインケース', url: amazonSearchUrl('小型コインケース') },
      ],
    },
    {
      title: '遠征便利グッズ枠',
      text: '圧縮袋、折りたためるサブバッグ、薄手の上着があると、物販後や夜行移動で動きやすくなります。',
      links: [
        { label: '衣類圧縮袋', url: amazonSearchUrl('衣類圧縮袋') },
        { label: '折りたたみサブバッグ', url: amazonSearchUrl('折りたたみサブバッグ') },
        { label: '薄手パーカー', url: amazonSearchUrl('薄手パーカー') },
      ],
    },
    {
      title: 'ホテル・宿泊エリア案内枠',
      text: '終演後に焦らないよう、駅までの距離とチェックイン時間を先に見ておくと安心です。',
      links: [
        { label: '吊り下げトラベルポーチ', url: amazonSearchUrl('吊り下げトラベルポーチ') },
        { label: 'USB-C急速充電器', url: amazonSearchUrl('USB-C急速充電器') },
        { label: '耳栓 アイマスク セット', url: amazonSearchUrl('耳栓 アイマスク セット') },
      ],
    },
    {
      title: '雨の日対策グッズ枠',
      text: '折りたたみ傘、防水袋、替えの靴下、タオルを増やしすぎない範囲で用意します。',
      links: [
        { label: '軽量折りたたみ傘', url: amazonSearchUrl('軽量折りたたみ傘') },
        { label: 'スマホ防水ケース', url: amazonSearchUrl('スマホ防水ケース') },
        { label: '速乾タオル', url: amazonSearchUrl('速乾タオル') },
      ],
    },
    {
      title: 'モバイルバッテリー枠',
      text: '電子チケット、地図、終電確認を使う日は、軽量タイプを1つ入れておくと余裕が残ります。',
      links: [
        { label: 'Anker Nano Power Bank 5000mAh', url: amazonSearchUrl('Anker Nano Power Bank 5000mAh') },
        { label: 'Anker PowerCore 10000', url: amazonSearchUrl('Anker PowerCore 10000') },
        { label: 'USB-Cケーブル 1m', url: amazonSearchUrl('USB-Cケーブル 1m') },
      ],
    },
  ],
} = Astro.props;
---

<aside class="gothic-card rounded-xl p-5 md:p-6">
  <p class="gothic-label">Preparation</p>
  <h2 class="font-classical mt-2 text-2xl font-black leading-tight text-mist">{title}</h2>
  <p class="mt-3 text-sm leading-7 text-muted">{lead}</p>
  <div class="mt-5 grid gap-3 md:grid-cols-2">
    {items.map((item) => (
      <div class="rounded-md border border-amber/20 bg-black/25 p-4">
        <p class="font-classical font-black text-mist">{item.title}</p>
        <p class="mt-2 text-sm leading-7 text-muted">{item.text}</p>
        {item.links && item.links.length > 0 && (
          <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-muted">
            {item.links.map((link) => (
              <li>
                <a class="text-amber underline decoration-amber/40 underline-offset-4 transition hover:text-mist" href={link.url} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>
  <p class="mt-4 text-xs leading-6 text-muted">
    このセクションにはアフィリエイトリンクが含まれます。商品は実用性を優先して選定しており、購入により当サイトに報酬が入る場合があります。
  </p>
</aside>
