---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<section class="mb-6">
  {eyebrow && <p class="mb-2 text-xs font-black uppercase tracking-[0.18em] text-cyan">{eyebrow}</p>}
  <h2 class="text-2xl font-black leading-tight text-white md:text-3xl">{title}</h2>
  {lead && <p class="mt-3 max-w-3xl text-sm leading-7 text-muted md:text-base">{lead}</p>}
</section>
