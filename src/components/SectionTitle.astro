---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<div class="mx-auto max-w-6xl px-4">
  <div class="mb-5">
    {eyebrow && (
      <p class="mb-2 text-xs font-bold uppercase tracking-[0.25em] text-fuchsia-300">
        {eyebrow}
      </p>
    )}

    <h2 class="text-2xl font-black text-white sm:text-3xl">
      {title}
    </h2>

    {lead && (
      <p class="mt-3 max-w-3xl text-sm leading-7 text-zinc-300 sm:text-base">
        {lead}
      </p>
    )}
  </div>
</div>
