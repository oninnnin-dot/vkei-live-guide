---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<section class="mb-6">
  {eyebrow && <p class="gothic-label mb-2">{eyebrow}</p>}
  <h2 class="font-classical text-2xl font-black leading-tight text-mist md:text-3xl">{title}</h2>
  <div class="ornament-line mt-3 max-w-xs"></div>
  {lead && <p class="mt-3 max-w-3xl text-sm leading-7 text-muted md:text-base">{lead}</p>}
</section>
