---
interface Props {
  title?: string;
  tone?: 'default' | 'warning' | 'success';
}

const { title = '確認メモ', tone = 'default' } = Astro.props;

const toneClass = {
  default: 'border-violet-400/40 bg-violet-500/10',
  warning: 'border-amber-400/50 bg-amber-500/10',
  success: 'border-cyan-400/50 bg-cyan-500/10',
}[tone];
---

<div class:list={["rounded-2xl border p-4 text-sm leading-7 text-zinc-200", toneClass]}>
  <h2 class="mb-2 font-bold text-white">{title}</h2>
  <div>
    <slot />
  </div>
</div>
