---
interface Props {
  title?: string;
  tone?: 'default' | 'warning' | 'success';
}

const { title = '確認メモ', tone = 'default' } = Astro.props;
const toneClass = {
  default: 'border-amber/35 bg-black/35',
  warning: 'border-amber/55 bg-violet/20',
  success: 'border-amber/55 bg-[#0b1020]/55',
}[tone];
---

<aside class={`rounded-xl border ${toneClass} p-4 text-sm leading-7 text-mist shadow-glow`}>
  <p class="font-classical mb-2 font-black text-mist">{title}</p>
  <slot />
</aside>
