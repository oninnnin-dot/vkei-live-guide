---
import type { Venue } from '@/types';

interface Props {
  venue: Venue;
}

const { venue } = Astro.props;

const cleanText = (value: unknown) => String(value ?? '').trim();
const cafes = (venue.nearbyInfo?.cafes ?? []).map(cleanText).filter(Boolean);
const areaQuery = venue.area || venue.station || venue.name;

const spotLinks = [
  {
    title: 'コンセントが使えるカフェ',
    text: cafes.length > 0 ? cafes.slice(0, 3).join(' / ') : `${areaQuery}駅側で、長時間滞留しない待機先を探す。`,
    url: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${areaQuery} カフェ コンセント`)}`,
  },
  {
    title: 'ヘアセット・身支度',
    text: '開場直前に会場前で直すより、駅側で先に整える前提にする。',
    url: `https://beauty.hotpepper.jp/keyword/${encodeURIComponent(`${areaQuery} ヘアセット`)}/`,
  },
  {
    title: 'プリクラ・写真整理',
    text: '特典会や終演後に寄る場合は、駅へ戻る導線から外れすぎない場所を選ぶ。',
    url: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${areaQuery} プリクラ`)}`,
  },
  {
    title: '推し色ドリンク・軽食',
    text: '飲食店は混雑と営業時間が変わりやすいので、駅側の候補を複数持つ。',
    url: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${areaQuery} カフェ ドリンク`)}`,
  },
];
---

<section class="gothic-card rounded-xl p-5 md:p-6">
  <div class="section-title">
    <p>Oshikatsu spots</p>
    <h2>開演前・終演後に使いやすい周辺スポット</h2>
    <p>充電、身支度、写真、軽食は、会場前に長くたまらないための逃げ場として候補を持っておきます。</p>
  </div>

  <div class="grid gap-3 md:grid-cols-2">
    {spotLinks.map((item) => (
      <a class="rounded-md border border-amber/20 bg-black/25 p-4 transition hover:border-amber/60" href={item.url} target="_blank" rel="noopener noreferrer">
        <span class="font-classical block text-base font-black text-mist">{item.title}</span>
        <span class="mt-2 block text-sm leading-7 text-muted">{item.text}</span>
        <span class="mt-3 inline-block text-sm font-black text-amber underline decoration-amber/40 underline-offset-4">地図・予約候補を見る</span>
      </a>
    ))}
  </div>

  <p class="mt-4 text-xs leading-6 text-muted">
    店舗の営業時間、電源利用、混雑、クーポン条件は変わります。会場周辺で長く滞留せず、駅側や商業施設側で調整するための候補として使ってください。
  </p>
</section>
