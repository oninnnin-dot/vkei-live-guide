---
interface Props {
  title: string;
  description: string;
  href: string;
  note?: string;
  cta?: string;
}

const { title, description, href, note, cta = '開く' } = Astro.props;
const isExternal = href.startsWith('http');
---

<a
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noreferrer' : undefined}
  class="block rounded-2xl border border-white/10 bg-zinc-950/80 p-5 shadow-lg shadow-black/30 transition hover:-translate-y-0.5 hover:border-fuchsia-400/50 hover:bg-zinc-900"
>
  <h3 class="text-lg font-black text-white">
    {title}
  </h3>

  <p class="mt-3 text-sm leading-7 text-zinc-300">
    {description}
  </p>

  {note && (
    <p class="mt-3 rounded-xl bg-white/5 p-3 text-xs leading-6 text-zinc-400">
      {note}
    </p>
  )}

  <span class="mt-4 inline-flex min-h-10 items-center rounded-full bg-fuchsia-500 px-4 py-2 text-sm font-bold text-white">
    {cta}
  </span>
</a>
