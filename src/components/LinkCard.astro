---
interface Props {
  title: string;
  description: string;
  href: string;
  note?: string;
  cta?: string;
}

const { title, description, href, note, cta = '公式ページを開く' } = Astro.props;
const isExternal = href.startsWith('http');
---

<a
  class="focus-ring group flex h-full min-w-0 flex-col rounded-lg border border-line bg-panel p-5 shadow-glow transition hover:-translate-y-0.5 hover:border-violet/70"
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  <span class="text-lg font-black leading-snug text-white">{title}</span>
  <span class="mt-2 flex-1 text-sm leading-7 text-muted">{description}</span>
  {note && <span class="mt-4 rounded-md border border-line bg-black/20 px-3 py-2 text-xs leading-6 text-muted">{note}</span>}
  <span class="mt-5 inline-flex min-h-11 items-center justify-center rounded-md bg-violet px-4 py-2 text-center text-sm font-black leading-snug text-white transition group-hover:bg-magenta">
    {cta}
  </span>
</a>
