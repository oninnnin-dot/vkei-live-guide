---
interface Props {
  title: string;
  description: string;
  href: string;
  note?: string;
  cta?: string;
}

const { title, description, href, note, cta = '開く' } = Astro.props;
const isExternal = href.startsWith('http');
---

<a
  class="gothic-card focus-ring group flex h-full min-w-0 flex-col rounded-xl p-5 transition hover:-translate-y-0.5 hover:border-amber/60"
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  <span class="font-classical pt-2 text-lg font-black leading-snug text-mist">{title}</span>
  <span class="mt-2 flex-1 text-sm leading-7 text-muted">{description}</span>
  {note && <span class="mt-4 rounded-md border border-amber/20 bg-black/30 px-3 py-2 text-xs leading-6 text-muted">{note}</span>}
  <span class="gothic-button mt-5 inline-flex min-h-11 items-center justify-center rounded-md px-4 py-2 text-center text-sm font-black leading-snug transition">
    {cta}
  </span>
</a>
