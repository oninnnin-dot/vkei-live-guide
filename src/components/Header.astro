---
const navItems = [
  { href: '/weekend', label: 'ライブを探す' },
  { href: '/venues', label: '会場攻略' },
  { href: '/venues/regions', label: '地域別' },
  { href: '/venues/types', label: '会場種類' },
  { href: '/guides/small-venue', label: '小箱初参戦' },
  { href: '/guides/livehouse-tips', label: '豆知識' },
  { href: '/guides/beginner', label: '初参戦' },
  { href: '/guides/belongings', label: '持ち物' },
  { href: '/tools/budget', label: '遠征費' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-black/85 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-3 text-white">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-fuchsia-500 font-black">
        V
      </span>
      <span>
        <span class="block text-sm font-black leading-tight">V系ライブ遠征ナビ</span>
        <span class="block text-xs text-zinc-400">小箱の不安を消す実用ナビ</span>
      </span>
    </a>

    <nav class="hidden items-center gap-2 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-3 py-2 text-sm font-semibold text-zinc-300 transition hover:bg-white/10 hover:text-white"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <nav class="flex gap-2 overflow-x-auto px-4 pb-3 md:hidden">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="shrink-0 rounded-full border border-white/10 bg-white/5 px-3 py-2 text-xs font-semibold text-zinc-200"
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>
