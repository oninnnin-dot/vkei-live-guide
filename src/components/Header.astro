---
const navItems = [
  { href: '/weekend', label: 'ライブを探す' },
  { href: '/venues', label: '会場攻略' },
  { href: '/venues/regions', label: '地域別' },
  { href: '/venues/types', label: '会場種類' },
  { href: '/guides/small-venue', label: '小箱初参戦' },
  { href: '/guides/livehouse-tips', label: '豆知識' },
  { href: '/guides/beginner', label: '初参戦' },
  { href: '/guides/belongings', label: '持ち物' },
  { href: '/tools/budget', label: '遠征費' },
];
---

<header class="sticky top-0 z-40 border-b border-amber/25 bg-black/90 backdrop-blur">
  <div class="container-navi flex min-h-16 flex-col gap-3 overflow-hidden py-3 lg:flex-row lg:items-center lg:justify-between">
    <a href="/" class="focus-ring flex shrink-0 items-center gap-3 rounded-md" aria-label="V系ライブ遠征ナビ トップへ">
      <span class="grid size-10 place-items-center rounded-md border border-amber/55 bg-black text-lg font-black text-amber shadow-glow">V</span>
      <span class="leading-tight">
        <span class="font-classical block text-sm font-black tracking-wide text-mist">V系ライブ遠征ナビ</span>
        <span class="block text-xs text-muted">小箱の不安を消す実用ナビ</span>
      </span>
    </a>
    <nav class="grid w-full min-w-0 grid-cols-2 gap-2 lg:flex lg:w-auto lg:flex-wrap lg:justify-end" aria-label="主要メニュー">
      {
        navItems.map((item) => (
          <a class="focus-ring inline-flex min-h-10 min-w-0 items-center justify-center rounded-md border border-amber/20 bg-black/35 px-2.5 py-2 text-center text-sm font-bold leading-snug text-mist transition hover:border-amber/60 hover:bg-violet/25 hover:text-amber lg:shrink-0 lg:px-3" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
