---
const groups = [
  {
    title: '絶対に忘れたくない',
    items: [
      ['ticket', 'チケット'],
      ['id', '身分証'],
      ['cash', '現金'],
      ['ic', '交通系IC'],
      ['battery', 'モバイルバッテリー'],
    ],
  },
  {
    title: 'ライブ中・物販',
    items: [
      ['towel', 'タオル'],
      ['drink', '飲み物'],
      ['earplug', '耳栓'],
      ['goodsbag', '物販用バッグ'],
      ['coin', 'ロッカー用の小銭またはIC残高'],
    ],
  },
  {
    title: '遠征・天候・体調',
    items: [
      ['umbrella', '折りたたみ傘'],
      ['makeup', 'メイク直し'],
      ['medicine', '常備薬'],
      ['clothes', '着替え'],
      ['compression', '圧縮袋'],
    ],
  },
];
---

<section class="rounded-lg border border-line bg-panel p-5 shadow-glow" data-checklist data-storage-key="vkei-belongings-checklist">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm font-black text-cyan">Checklist</p>
      <div class="mt-1 text-2xl font-black text-white" role="heading" aria-level="2">持ち物チェック</div>
    </div>
    <button class="focus-ring min-h-11 rounded-md border border-line px-4 py-2 text-sm font-black text-mist hover:border-violet/70" type="button" data-reset>
      リセット
    </button>
  </div>
  <div class="mt-5 rounded-md border border-line bg-black/20 p-4">
    <div class="flex items-center justify-between gap-3 text-sm">
      <span class="font-bold text-muted">チェック済み</span>
      <span class="font-black text-white" data-count>0/0</span>
    </div>
    <div class="mt-3 h-3 overflow-hidden rounded-full bg-line">
      <span class="block h-full w-0 rounded-full bg-cyan transition-all" data-progress></span>
    </div>
  </div>
  <div class="mt-6 grid gap-5 md:grid-cols-3">
    {
      groups.map((group) => (
        <div class="rounded-md border border-line bg-black/20 p-4">
          <div class="font-black text-white" role="heading" aria-level="3">{group.title}</div>
          <div class="mt-4 space-y-3">
            {group.items.map(([id, label]) => (
              <label class="flex min-h-11 cursor-pointer items-center gap-3 rounded-md border border-line bg-panel px-3 py-2 text-sm text-mist transition hover:border-violet/70">
                <input class="size-5 accent-violet" type="checkbox" value={id} />
                <span>{label}</span>
              </label>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  const root = document.querySelector('[data-checklist]');
  if (root) {
    const boxes = Array.from(root.querySelectorAll('input[type="checkbox"]'));
    const count = root.querySelector('[data-count]');
    const progress = root.querySelector('[data-progress]');
    const reset = root.querySelector('[data-reset]');
    const storageKey = root.getAttribute('data-storage-key') || 'checklist';

    const saved = JSON.parse(localStorage.getItem(storageKey) || '[]');
    boxes.forEach((box) => {
      box.checked = saved.includes(box.value);
    });

    const sync = () => {
      const checked = boxes.filter((box) => box.checked).map((box) => box.value);
      localStorage.setItem(storageKey, JSON.stringify(checked));
      if (count) count.textContent = `${checked.length}/${boxes.length}`;
      if (progress) progress.style.width = `${boxes.length === 0 ? 0 : (checked.length / boxes.length) * 100}%`;
    };

    boxes.forEach((box) => box.addEventListener('change', sync));
    reset?.addEventListener('click', () => {
      boxes.forEach((box) => {
        box.checked = false;
      });
      sync();
    });
    sync();
  }
</script>
