---
import type { Venue } from '@/types';

interface Props {
  venue: Venue;
  compact?: boolean;
}

const { venue, compact = false } = Astro.props;

const scaleLabel = {
  small: '小箱',
  'small-mid': '小〜中箱',
  mid: '中箱',
  large: '大箱',
  unknown: '規模要確認',
}[venue.venueScale];

const typeLabel = {
  small_livehouse: '小箱ライブハウス',
  mid_livehouse: '中箱ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '要確認',
}[venue.venueType ?? 'unknown'];

const affinityLabel = {
  high: 'V系利用傾向: 高',
  medium: 'V系利用傾向: 中',
  low: 'V系利用傾向: 低',
  unknown: 'V系利用傾向: 要確認',
}[venue.vkeiAffinity];

const confidenceLabel = {
  verified: '公式・一次情報確認済み',
  partially_verified: '一部確認済み',
  social_only: 'SNS言及ベース',
  verified_or_historical: '履歴情報として確認',
  unknown: '要確認',
}[venue.sourceConfidence ?? 'unknown'];

const sourceNotes = Array.isArray(venue.sourceNotes)
  ? venue.sourceNotes
  : venue.sourceNotes
    ? [String(venue.sourceNotes)]
    : [];
const sourceNotesText = sourceNotes.join(' ');
const equipmentNeedsCheck =
  sourceNotesText.includes('設備情報は要確認') ||
  sourceNotesText.includes('公式URL・設備情報は要確認') ||
  ['partially_verified', 'social_only', 'unknown'].includes(venue.sourceConfidence ?? 'unknown');

const lockerText = [venue.lockerNote, venue.lockerStrategy, venue.cloakStrategy]
  .filter(Boolean)
  .join(' ');
const hasSpecificLockerText =
  /ロッカーなし|店内ロッカーなし|ロッカーはない|ロッカーはある|会場ロッカーはある|クローク利用|クローク利用前提|コインロッカーはない/.test(lockerText);
const lockerFactLabel = hasSpecificLockerText
  ? lockerText
  : equipmentNeedsCheck
    ? '設備情報は公式・主催者案内で要確認'
    : lockerText || 'ロッカー・クローク情報は未登録';

const accessLabel = venue.station
  ? `${venue.station}${typeof venue.walkMinutes === 'number' ? ` / 徒歩目安 ${venue.walkMinutes}分` : ' / 徒歩目安 要確認'}`
  : '最寄り駅 要確認';

const displayBadges = [
  typeLabel,
  scaleLabel,
  venue.minorVkeiFriendly ? '若手・マイナーV系候補' : '',
  venue.vkeiUseType === 'release_event' ? 'リリースイベント枠' : '',
  venue.archiveOnly ? '閉館アーカイブ' : '',
].filter(Boolean);

const visibleTipTags = (venue.tipTags ?? []).slice(0, 3);
const hiddenTipCount = Math.max((venue.tipTags ?? []).length - visibleTipTags.length, 0);

const tipFilterMap: Record<string, string> = {
  ロッカー注意: 'tip-locker',
  クローク確認: 'tip-cloak',
  駅ロッカー推奨: 'tip-station-locker',
  現金必要: 'tip-cash',
  '100円玉必要': 'tip-coin',
  再入場不可注意: 'tip-no-reentry',
  地下会場: 'tip-basement',
  階段混雑注意: 'tip-stairs',
  トイレ少なめ: 'tip-restroom',
  終演後混雑: 'tip-return-crowd',
  近隣待機注意: 'tip-neighborhood',
  歌舞伎町エリア注意: 'tip-kabukicho',
  渋谷人混み注意: 'tip-shibuya-crowd',
  遠征荷物注意: 'tip-travel-baggage',
  物販後荷物注意: 'tip-merch-baggage',
  ぼっち参戦向き: 'tip-solo',
  初参戦は入口確認: 'tip-entry-check',
};
const tipFilterTags = (venue.tipTags ?? []).map((tag) => tipFilterMap[tag]).filter(Boolean);

const searchText = [
  venue.name,
  ...(venue.aliases ?? []),
  venue.area,
  venue.prefecture,
  venue.region,
  venue.station,
  venue.venueType,
  venue.venueScale,
  venue.vkeiAffinity,
  venue.vkeiUseType,
  typeLabel,
  scaleLabel,
  affinityLabel,
  lockerFactLabel,
  ...(venue.tipTags ?? []),
].filter(Boolean).join(' ');

const filterTags = [
  'all',
  venue.venueScale === 'small' ? 'small' : '',
  venue.venueScale === 'small-mid' || venue.venueScale === 'mid' ? 'mid' : '',
  venue.venueScale === 'large' ? 'large' : '',
  venue.venueType,
  venue.vkeiAffinity === 'high' ? 'vkei-high' : '',
  venue.minorVkeiFriendly ? 'minor-vkei' : '',
  venue.vkeiUseType === 'release_event' ? 'release-event' : '',
  venue.vkeiUseType === 'large_scale' || venue.venueType === 'hall' ? 'large-hall' : '',
  ['partially_verified', 'social_only', 'unknown'].includes(venue.sourceConfidence) ? 'needs-check' : '',
  hasSpecificLockerText ? 'locker-fact' : '',
  venue.region,
  venue.prefecture,
  venue.areaGroup,
  venue.area === '横浜' || venue.areaGroup?.includes('yokohama') ? 'yokohama' : '',
  venue.area === '渋谷' || venue.areaGroup?.includes('shibuya') ? 'shibuya' : '',
  venue.area === '下北沢' || venue.areaGroup?.includes('shimokitazawa') ? 'shimokitazawa' : '',
  venue.area === '池袋' || venue.areaGroup?.includes('ikebukuro') ? 'ikebukuro' : '',
  ...tipFilterTags,
].filter(Boolean).join(' ');
---

<article
  class={`flex h-full min-w-0 flex-col rounded-lg border border-line bg-panel p-5 shadow-glow ${venue.archiveOnly || venue.status === 'closed' || !venue.showInVenueList ? 'hidden' : ''}`}
  data-venue-card
  data-default-visible={venue.status !== 'closed' && venue.showInVenueList && !venue.archiveOnly ? 'true' : 'false'}
  data-archive={venue.archiveOnly ? 'true' : 'false'}
  data-status={venue.status}
  data-name={venue.name}
  data-region={venue.region}
  data-prefecture={venue.prefecture}
  data-area={venue.area}
  data-type={venue.venueType}
  data-scale={venue.venueScale}
  data-affinity={venue.vkeiAffinity}
  data-minor={venue.minorVkeiFriendly ? 'true' : 'false'}
  data-priority={venue.priority}
  data-locker-info={hasSpecificLockerText ? '1' : '0'}
  data-tags={(venue.tipTags ?? []).join('|')}
  data-search={searchText}
  data-filter-tags={filterTags}
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <span class="inline-flex rounded-full border border-cyan/35 bg-cyan/10 px-2.5 py-1 text-xs font-black text-cyan">{venue.area} / {venue.prefecture}</span>
      <h3 class="mt-2 text-xl font-black leading-tight text-white">{venue.name}</h3>
      <p class="mt-2 text-sm leading-6 text-muted">最寄り: {accessLabel}</p>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    {displayBadges.map((badge) => (
      <span class="rounded-full border border-violet/45 bg-violet/10 px-3 py-1 text-xs font-black text-mist">{badge}</span>
    ))}
  </div>

  {visibleTipTags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {visibleTipTags.map((tag) => <span class="rounded-full border border-cyan/35 bg-cyan/10 px-2.5 py-1 text-[11px] font-black text-mist">{tag}</span>)}
      {hiddenTipCount > 0 && <span class="rounded-full border border-line bg-black/20 px-2.5 py-1 text-[11px] font-black text-muted">他{hiddenTipCount}件</span>}
    </div>
  )}

  <dl class="mt-4 grid gap-2 text-sm">
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-line bg-black/20 px-3 py-2">
      <dt class="text-muted">会場種別</dt>
      <dd class="min-w-0 text-right font-black text-white">{typeLabel}</dd>
    </div>
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-line bg-black/20 px-3 py-2">
      <dt class="text-muted">V系利用傾向</dt>
      <dd class="min-w-0 text-right font-black text-white">{affinityLabel}</dd>
    </div>
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-line bg-black/20 px-3 py-2">
      <dt class="text-muted">設備確認</dt>
      <dd class="min-w-0 text-right font-black text-white">{equipmentNeedsCheck ? '設備情報は要確認' : '設備情報メモあり'}</dd>
    </div>
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-line bg-black/20 px-3 py-2">
      <dt class="text-muted">情報確度</dt>
      <dd class="min-w-0 text-right font-black text-white">{confidenceLabel}</dd>
    </div>
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-line bg-black/20 px-3 py-2">
      <dt class="text-muted">確認日</dt>
      <dd class="min-w-0 text-right font-black text-white">{venue.lastVerifiedAt}</dd>
    </div>
  </dl>

  {!compact && (
    <p class="mt-4 flex-1 text-sm leading-7 text-muted">
      {venue.currentUseNote || venue.beginnerNote || sourceNotesText}
    </p>
  )}

  {compact && (
    <p class="mt-4 flex-1 text-xs leading-6 text-muted">
      ロッカー/クローク: {lockerFactLabel}
    </p>
  )}

  <a class="focus-ring mt-5 inline-flex min-h-11 items-center justify-center rounded-md bg-violet px-4 py-2 text-sm font-black text-white transition hover:bg-magenta" href={`/venues/${venue.slug}`}>
    詳細を見る
  </a>
</article>
