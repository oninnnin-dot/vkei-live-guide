---
import type { Venue } from '@/types';
import { getAreaSortRank, getRegionSortRank, getVenueInfoScore, TOKYO_PRIORITY_SLUGS } from '@/utils/venueSort';

interface Props {
  venue: Venue;
  compact?: boolean;
}

const { venue, compact = false } = Astro.props;

const scaleLabels: Record<string, string> = {
  small: '小規模',
  'small-mid': '小〜中規模',
  mid: '中規模',
  large: '大型',
  unknown: '規模確認中',
};

const typeLabels: Record<string, string> = {
  small_livehouse: '小規模ライブハウス',
  mid_livehouse: '中規模ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '種別確認中',
};

const lockerStatusLabels: Record<string, string> = {
  available: 'あり',
  limited: '少数',
  none: 'なし',
  unknown: '確認中',
};

const cloakStatusLabels: Record<string, string> = {
  available: 'あり',
  event_dependent: '公演による',
  none: 'なし',
  unknown: '確認中',
};

const stationLockerLabels: Record<string, string> = {
  yes: '駅ロッカー先行がおすすめ',
  depends: '荷物量・整理番号次第',
  situation_dependent: '荷物量・整理番号次第',
  conditional: '荷物量・整理番号次第',
  no: '会場設備で足りる可能性あり',
  unknown: '状況次第',
};

const cleanText = (value: unknown) =>
  String(value ?? '')
    .replace(/\bunknown\b/g, '確認中')
    .replaceAll('未確認', '確認中')
    .replaceAll('未調査', '確認中')
    .replaceAll('ヴィジュアル系', '推し活')
    .replaceAll('ビジュアル系', '推し活')
    .replaceAll('V系', '推し活')
    .replaceAll('小箱ライブ', '小規模会場')
    .replaceAll('小箱', '小規模')
    .trim();

const genericPublicPhrases = [
  '荷物が多い日は駅ロッカーかホテル預けを先に決める',
  '駅周辺で時間調整する',
  '周辺情報は確認中です',
  '大荷物は駅側で荷物処理',
  '公式アクセス参照',
  '地図アプリで直前確認',
  '荷物が多い日は最寄り駅や主要駅ロッカーも候補',
  '整列開始までは会場前に長くたまらず、駅周辺で時間調整する',
  '雨の日は駅周辺や商業施設など屋根のある場所で整える',
  '入場前に駅や周辺施設で済ませる',
  '終演後は駅までの導線と荷物回収時間を先に決める',
  '初めての会場は帰りの駅ルートを事前保存する',
  '周辺コンビニは事前に地図アプリで確認推奨',
  '開場前の待機は近隣迷惑にならないよう',
  '夜の帰り道は駅までのルートを事前確認推奨',
  '終演後はまず荷物回収と駅までのルート',
  '背中のリュックはフロアで邪魔になりやすい',
  '最寄り駅周辺ロッカーは埋まることがある',
  'コンビニは周辺にあり',
  '荷物が多い日は駅で確認',
];

const isGenericPublicText = (value: unknown) => {
  const text = cleanText(value);
  return genericPublicPhrases.some((phrase) => text.includes(phrase));
};

const isUseful = (value: unknown) => {
  const text = cleanText(value);
  return (
    Boolean(text) &&
    text !== '確認中' &&
    text !== 'なし' &&
    !text.includes('確認中') &&
    !text.includes('未確認') &&
    !text.includes('未調査') &&
    !text.includes('対象外') &&
    !isGenericPublicText(text)
  );
};

const toUsefulList = (value: unknown) => {
  const values = Array.isArray(value) ? value : [value];
  return values.map(cleanText).filter((item) => isUseful(item));
};

const firstUsefulText = (...values: unknown[]) => {
  for (const value of values) {
    const list = toUsefulList(value);
    if (list.length > 0) return list.slice(0, 2).join(' / ');
  }
  return '';
};

const placeNames = (type: string) =>
  (venue.nearbyInfo?.places ?? [])
    .filter((place) => place.type === type)
    .map((place) => {
      const detail = [place.directionNote, typeof place.walkMinutes === 'number' ? `徒歩目安${place.walkMinutes}分` : '']
        .filter(Boolean)
        .join('・');
      return detail ? `${place.name}（${detail}）` : place.name;
    });

const shortenText = (value: unknown, maxLength = 58) => {
  const text = cleanText(value);
  return text.length > maxLength ? `${text.slice(0, maxLength - 1)}…` : text;
};

const normalizeStationLocker = (value: unknown) => {
  if (value === true) return 'yes';
  if (value === false) return 'no';
  return String(value || 'unknown');
};

const effectiveVenueStatus = venue.venueStatus ?? venue.status;
const isArchive = venue.archiveOnly || effectiveVenueStatus === 'closed';
const infoScore = getVenueInfoScore(venue);
const regionSortRank = getRegionSortRank(venue);
const areaSortRank = getAreaSortRank(venue);
const tokyoPriorityRank = TOKYO_PRIORITY_SLUGS.indexOf(venue.slug as (typeof TOKYO_PRIORITY_SLUGS)[number]);
const lockerState = venue.lockerInfo?.venueLockerStatus ?? 'unknown';
const cloakState = venue.cloakInfo?.cloakStatus ?? 'unknown';
const stationLockerState = normalizeStationLocker(
  venue.lockerInfo?.stationLockerRecommended ??
  (venue.nearbyInfo?.stationLocker ? 'yes' : 'unknown')
);

const typeLabel = typeLabels[venue.venueType ?? 'unknown'];
const scaleLabel = scaleLabels[venue.venueScale ?? 'unknown'];

const accessLabel = firstUsefulText(
  venue.nearbyInfo?.nearestExit ? `${venue.station || '最寄駅'} / ${venue.nearbyInfo.nearestExit}` : '',
  venue.station ? `${venue.station}${typeof venue.walkMinutes === 'number' ? ` / 徒歩目安 ${venue.walkMinutes}分` : ''}` : ''
) || '最寄り確認中';

const baggageOneLine = isArchive
  ? '閉館アーカイブのため、現在利用前提の荷物案内は表示していません。'
  : firstUsefulText(
      venue.practicalSummary?.headline,
      venue.lockerInfo?.bestMove,
      venue.baggageGuide?.backpack,
      venue.baggageNote
    ) || '30秒結論は確認中です。';

const quickRows = isArchive ? [] : [
  ['最寄出口', venue.nearbyInfo?.nearestExit],
  ['コンビニ', firstUsefulText(placeNames('convenience_store'), venue.nearbyInfo?.convenienceStores, venue.nearbyInfo?.nearestConvenienceStore, venue.nearbyInfo?.convenienceStore)],
  ['待機', venue.nearbyInfo?.waitingRule || venue.nearbyInfo?.waitingSpot],
  ['終演後', venue.nearbyInfo?.afterShowRoute],
  ['夜道', venue.nearbyInfo?.nightSafety],
  ['荷物', firstUsefulText(venue.nearbyInfo?.baggageFlow, venue.lockerInfo?.bestMove, venue.baggageGuide?.backpack, stationLockerState !== 'unknown' ? stationLockerLabels[stationLockerState] : '')],
].filter(([, value]) => isUseful(value)) as Array<[string, string]>;

const hasHiddenUnknowns = false;

const publicTipTags = (venue.tipTags ?? []).map(cleanText).filter(Boolean);
const derivedTipTags = [
  lockerState === 'available' ? 'ロッカーあり' : '',
  cloakState === 'available' || cloakState === 'event_dependent' ? 'クロークあり' : '',
  stationLockerState === 'yes' ? '駅ロッカー推奨' : '',
  venue.nearbyInfo?.convenienceStores?.length ? 'コンビニ近い' : '',
  venue.nearbyInfo?.waitingRule ? '待機注意' : '',
  venue.nearbyInfo?.rainPlan ? '雨の日注意' : '',
  venue.nearbyInfo?.afterShowRoute ? '終演後注意' : '',
  venue.nearbyInfo?.nightSafety ? '女性ソロ注意' : '',
  venue.nearbyInfo?.soloBeginnerNote ? '初参戦向き' : '',
  venue.baggageGuide?.suitcase || venue.nearbyInfo?.tripNote?.includes('キャリー') ? 'キャリー非推奨' : '',
].filter(Boolean);
const cardFilterTags = [...new Set([...publicTipTags, ...derivedTipTags])];
const visibleTipTags = cardFilterTags.slice(0, compact ? 6 : 8);
const hiddenTipCount = Math.max(cardFilterTags.length - visibleTipTags.length, 0);

const logisticsSearchText = isArchive ? [] : [
  venue.lockerInfo?.venueLockerText,
  venue.lockerInfo?.lockerCountText,
  venue.lockerInfo?.bestMove,
  venue.cloakInfo?.cloakText,
  venue.cloakInfo?.priceText,
  venue.cloakInfo?.bestMove,
  venue.baggageGuide?.backpack,
  venue.nearbyInfo?.nearestExit,
  ...(venue.nearbyInfo?.convenienceStores ?? []),
  ...(venue.nearbyInfo?.stationLockers ?? []),
  ...(venue.nearbyInfo?.restrooms ?? []),
  ...(venue.nearbyInfo?.places ?? []).map((place) => `${place.name} ${place.directionNote ?? ''}`),
  venue.nearbyInfo?.waitingRule,
  venue.nearbyInfo?.rainPlan,
  venue.nearbyInfo?.soloBeginnerNote,
  venue.nearbyInfo?.tripNote,
  venue.nearbyInfo?.baggageFlow,
  venue.nearbyInfo?.stationLocker,
  venue.nearbyInfo?.waitingSpot,
  venue.nearbyInfo?.afterShowRoute,
  venue.nearbyInfo?.dayFlow?.stationArrival,
  venue.nearbyInfo?.dayFlow?.baggageDrop,
  venue.nearbyInfo?.dayFlow?.beforeEntry,
  venue.nearbyInfo?.dayFlow?.entry,
  venue.nearbyInfo?.dayFlow?.afterShow,
  ...(venue.practicalSummary?.points ?? []),
].filter(isUseful);

const searchText = [
  venue.name,
  ...(venue.aliases ?? []),
  venue.area,
  venue.prefecture,
  venue.region,
  venue.station,
  venue.venueType,
  venue.venueScale,
  venue.vkeiAffinity,
  typeLabel,
  scaleLabel,
  baggageOneLine,
  ...logisticsSearchText,
  ...publicTipTags,
  ...derivedTipTags,
]
  .filter(Boolean)
  .map(cleanText)
  .join(' ');

const lockerSortRank: Record<string, number> = {
  none: 4,
  limited: 3,
  unknown: 2,
  available: 1,
};

const displayBadges = [
  typeLabel,
  scaleLabel,
  venue.archiveOnly ? '閉館アーカイブ' : '',
].filter((label) => Boolean(label) && !label.includes('確認中'));

const filterTags = [
  'all',
  venue.venueScale === 'small' ? 'small' : '',
  venue.venueScale === 'small-mid' || venue.venueScale === 'mid' ? 'mid' : '',
  venue.venueScale === 'large' ? 'large' : '',
  venue.venueType,
  venue.vkeiAffinity === 'high' ? 'affinity-high' : '',
  venue.minorVkeiFriendly ? 'small-scene' : '',
  venue.region,
  venue.prefecture,
  venue.areaGroup,
  venue.area,
  !isArchive && venue.lockerInfo ? 'locker-fact' : '',
  !isArchive && venue.nearbyInfo ? 'nearby-fact' : '',
  !isArchive && venue.nearbyInfo?.afterShowRoute ? 'return-fact' : '',
  !isArchive && venue.nearbyInfo?.convenienceStores?.length ? 'コンビニ近い' : '',
  !isArchive && venue.nearbyInfo?.waitingRule ? '待機注意' : '',
  !isArchive && venue.nearbyInfo?.rainPlan ? '雨の日注意' : '',
  !isArchive && venue.nearbyInfo?.nightSafety ? '女性ソロ注意' : '',
  !isArchive && (venue.lockerInfo?.venueLockerStatus === 'none' || venue.lockerInfo?.venueLockerStatus === 'limited') ? 'locker-attention' : '',
  !isArchive && (venue.cloakInfo?.cloakStatus === 'available' || venue.cloakInfo?.cloakStatus === 'event_dependent') ? 'cloak-available' : '',
  venue.area === '横浜' || venue.areaGroup?.includes('yokohama') ? 'yokohama' : '',
  venue.area === '渋谷' || venue.areaGroup?.includes('shibuya') ? 'shibuya' : '',
  venue.area === '下北沢' || venue.areaGroup?.includes('shimokitazawa') ? 'shimokitazawa' : '',
  venue.area === '池袋' || venue.areaGroup?.includes('ikebukuro') ? 'ikebukuro' : '',
].filter(Boolean).join(' ');
---

<article
  class={`gothic-card flex h-full min-w-0 flex-col rounded-xl p-5 ${isArchive || !venue.showInVenueList ? 'hidden' : ''}`}
  data-venue-card
  data-default-visible={effectiveVenueStatus !== 'closed' && venue.showInVenueList && !venue.archiveOnly ? 'true' : 'false'}
  data-archive={venue.archiveOnly ? 'true' : 'false'}
  data-status={effectiveVenueStatus}
  data-name={venue.name}
  data-region={venue.region}
  data-prefecture={venue.prefecture}
  data-area={venue.area}
  data-type={venue.venueType}
  data-scale={venue.venueScale}
  data-affinity={venue.vkeiAffinity}
  data-minor={venue.minorVkeiFriendly ? 'true' : 'false'}
  data-priority={venue.priority}
  data-locker-rank={lockerSortRank[lockerState] ?? 0}
  data-info-score={infoScore}
  data-region-rank={regionSortRank}
  data-area-rank={areaSortRank}
  data-tokyo-priority-rank={tokyoPriorityRank >= 0 ? tokyoPriorityRank : 999}
  data-tags={cardFilterTags.join('|')}
  data-search={searchText}
  data-filter-tags={filterTags}
>
  <div class="min-w-0 pt-2">
    <span class="gothic-chip inline-flex rounded-md px-2.5 py-1 text-xs font-black">{venue.area} / {venue.prefecture}</span>
    <h3 class="font-classical mt-3 text-xl font-black leading-tight text-mist">{venue.name}</h3>
    <p class="mt-2 text-sm leading-6 text-muted">最寄り: {accessLabel}</p>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    {displayBadges.map((badge) => (
      <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">{badge}</span>
    ))}
  </div>

  <div class="mt-4 rounded-lg border border-amber/20 bg-black/25 p-3">
    <p class="gothic-label">30秒結論</p>
    <p class="mt-2 text-sm font-black leading-7 text-mist">{shortenText(baggageOneLine, compact ? 64 : 88)}</p>
  </div>

  {quickRows.length > 0 && (
    <dl class="mt-4 grid gap-2 text-sm">
      {quickRows.map(([label, value]) => (
        <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-amber/20 bg-black/25 px-3 py-2">
          <dt class="text-muted">{label}</dt>
          <dd class="min-w-0 text-right font-black leading-6 text-mist">{shortenText(value, 62)}</dd>
        </div>
      ))}
    </dl>
  )}

  {hasHiddenUnknowns && (
    <p class="mt-3 rounded-md border border-amber/15 bg-black/20 px-3 py-2 text-xs font-bold leading-6 text-muted">
      設備詳細は確認中。荷物が多い日は駅ロッカー先行が無難です。
    </p>
  )}

  {visibleTipTags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {visibleTipTags.map((tag) => <span class="gothic-chip rounded-md px-2.5 py-1 text-[11px] font-black">{tag}</span>)}
      {hiddenTipCount > 0 && <span class="rounded-md border border-amber/20 bg-black/25 px-2.5 py-1 text-[11px] font-black text-muted">他{hiddenTipCount}件</span>}
    </div>
  )}

  {!compact && (
    <p class="mt-4 flex-1 text-sm leading-7 text-muted">
      {venue.beginnerOneLine || venue.currentUseNote || venue.beginnerNote}
    </p>
  )}

  <a class="gothic-button focus-ring mt-5 inline-flex min-h-11 items-center justify-center rounded-md px-4 py-2 text-sm font-black transition" href={`/venues/${venue.slug}`}>
    詳細を見る
  </a>
</article>
