---
import type { Venue } from '@/types';

interface Props {
  venue: Venue;
  compact?: boolean;
}

const { venue, compact = false } = Astro.props;

const scaleLabel = {
  small: '小箱',
  'small-mid': '小〜中箱',
  mid: '中箱',
  large: '大箱',
  unknown: '規模要確認',
}[venue.venueScale];

const typeLabel = {
  small_livehouse: '小箱ライブハウス',
  mid_livehouse: '中箱ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '要確認',
}[venue.venueType ?? 'unknown'];

const lockerStatusLabel = {
  available: 'あり',
  none: 'なし',
  limited: '少数',
  unknown: '未確認',
}[venue.lockerInfo?.venueLockerStatus ?? 'unknown'];

const cloakStatusLabel = {
  available: 'あり',
  none: 'なし',
  event_dependent: '公演による',
  unknown: '未確認',
}[venue.cloakInfo?.cloakStatus ?? 'unknown'];

const stationLockerLabel = {
  yes: 'はい',
  no: 'いいえ',
  depends: '状況次第',
  unknown: '未確認',
}[venue.lockerInfo?.stationLockerRecommended ?? (
  venue.nearbyInfo?.stationLocker ? 'yes' : 'unknown'
)];

const blogResearchLabel = {
  researched: '済',
  partial: '一部',
  not_found: '見つからず',
  not_started: '未調査',
}[venue.blogResearch?.status ?? 'not_started'];

const baggageOneLine =
  venue.lockerInfo?.bestMove ||
  venue.dayDecisionGuide?.baggageDay ||
  venue.baggageGuide?.backpack ||
  venue.practicalSummary?.headline ||
  venue.baggageNote ||
  '荷物が多い日は駅ロッカーかクロークを先に決める。';

const accessLabel = venue.station
  ? `${venue.station}${typeof venue.walkMinutes === 'number' ? ` / 徒歩目安 ${venue.walkMinutes}分` : ' / 徒歩目安 要確認'}`
  : '最寄り駅 要確認';

const visibleTipTags = (venue.tipTags ?? []).slice(0, 3);
const hiddenTipCount = Math.max((venue.tipTags ?? []).length - visibleTipTags.length, 0);

const searchText = [
  venue.name,
  ...(venue.aliases ?? []),
  venue.area,
  venue.prefecture,
  venue.region,
  venue.station,
  venue.venueType,
  venue.venueScale,
  venue.vkeiAffinity,
  venue.vkeiUseType,
  typeLabel,
  scaleLabel,
  baggageOneLine,
  venue.lockerInfo?.venueLockerText,
  venue.lockerInfo?.lockerCountText,
  venue.lockerInfo?.bestMove,
  venue.cloakInfo?.cloakText,
  venue.cloakInfo?.bestMove,
  venue.baggageGuide?.backpack,
  venue.nearbyInfo?.stationLocker,
  venue.nearbyInfo?.waitingSpot,
  venue.nearbyInfo?.afterShowRoute,
  venue.blogResearch?.summary,
  ...(venue.practicalSummary?.points ?? []),
  ...(venue.blogSignals ?? []).map((signal) => signal.summary),
  ...(venue.factChecks ?? []).map((fact) => `${fact.label} ${fact.body} ${fact.sourceLabel}`),
  ...(venue.tipTags ?? []),
].filter(Boolean).join(' ');

const lockerSortRank = {
  none: 4,
  limited: 3,
  unknown: 2,
  available: 1,
}[venue.lockerInfo?.venueLockerStatus ?? 'unknown'];

const displayBadges = [
  typeLabel,
  scaleLabel,
  venue.archiveOnly ? '閉館アーカイブ' : '',
].filter(Boolean);

const filterTags = [
  'all',
  venue.venueScale === 'small' ? 'small' : '',
  venue.venueScale === 'small-mid' || venue.venueScale === 'mid' ? 'mid' : '',
  venue.venueScale === 'large' ? 'large' : '',
  venue.venueType,
  venue.vkeiAffinity === 'high' ? 'vkei-high' : '',
  venue.minorVkeiFriendly ? 'minor-vkei' : '',
  ['partially_verified', 'social_only', 'unknown'].includes(venue.sourceConfidence) ? 'needs-check' : '',
  venue.lockerInfo ? 'locker-fact' : '',
  (venue.blogSignals ?? []).length > 0 ? 'community-fact' : '',
  venue.nearbyInfo ? 'nearby-fact' : '',
  venue.nearbyInfo?.afterShowRoute ? 'return-fact' : '',
  venue.region,
  venue.prefecture,
  venue.areaGroup,
  venue.area === '横浜' || venue.areaGroup?.includes('yokohama') ? 'yokohama' : '',
  venue.area === '渋谷' || venue.areaGroup?.includes('shibuya') ? 'shibuya' : '',
  venue.area === '下北沢' || venue.areaGroup?.includes('shimokitazawa') ? 'shimokitazawa' : '',
  venue.area === '池袋' || venue.areaGroup?.includes('ikebukuro') ? 'ikebukuro' : '',
].filter(Boolean).join(' ');
---

<article
  class={`gothic-card flex h-full min-w-0 flex-col rounded-xl p-5 ${venue.archiveOnly || venue.status === 'closed' || !venue.showInVenueList ? 'hidden' : ''}`}
  data-venue-card
  data-default-visible={venue.status !== 'closed' && venue.showInVenueList && !venue.archiveOnly ? 'true' : 'false'}
  data-archive={venue.archiveOnly ? 'true' : 'false'}
  data-status={venue.status}
  data-name={venue.name}
  data-region={venue.region}
  data-prefecture={venue.prefecture}
  data-area={venue.area}
  data-type={venue.venueType}
  data-scale={venue.venueScale}
  data-affinity={venue.vkeiAffinity}
  data-minor={venue.minorVkeiFriendly ? 'true' : 'false'}
  data-priority={venue.priority}
  data-locker-rank={lockerSortRank}
  data-tags={(venue.tipTags ?? []).join('|')}
  data-search={searchText}
  data-filter-tags={filterTags}
>
  <div class="min-w-0 pt-2">
    <span class="gothic-chip inline-flex rounded-md px-2.5 py-1 text-xs font-black">{venue.area} / {venue.prefecture}</span>
    <h3 class="font-classical mt-3 text-xl font-black leading-tight text-mist">{venue.name}</h3>
    <p class="mt-2 text-sm leading-6 text-muted">最寄り: {accessLabel}</p>
  </div>

  <div class="mt-4 flex flex-wrap gap-2">
    {displayBadges.map((badge) => (
      <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">{badge}</span>
    ))}
  </div>

  <div class="mt-4 rounded-lg border border-amber/20 bg-black/25 p-3">
    <p class="gothic-label">荷物の一言結論</p>
    <p class="mt-2 text-sm font-black leading-7 text-mist">{baggageOneLine}</p>
  </div>

  <dl class="mt-4 grid gap-2 text-sm">
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-amber/20 bg-black/25 px-3 py-2">
      <dt class="text-muted">会場内ロッカー</dt>
      <dd class="min-w-0 text-right font-black text-mist">{lockerStatusLabel}</dd>
    </div>
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-amber/20 bg-black/25 px-3 py-2">
      <dt class="text-muted">クローク</dt>
      <dd class="min-w-0 text-right font-black text-mist">{cloakStatusLabel}</dd>
    </div>
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-amber/20 bg-black/25 px-3 py-2">
      <dt class="text-muted">駅ロッカー推奨</dt>
      <dd class="min-w-0 text-right font-black text-mist">{stationLockerLabel}</dd>
    </div>
    <div class="grid grid-cols-[auto_1fr] gap-3 rounded-md border border-amber/20 bg-black/25 px-3 py-2">
      <dt class="text-muted">参戦レポ調査</dt>
      <dd class="min-w-0 text-right font-black text-mist">{blogResearchLabel}</dd>
    </div>
  </dl>

  {visibleTipTags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {visibleTipTags.map((tag) => <span class="gothic-chip rounded-md px-2.5 py-1 text-[11px] font-black">{tag}</span>)}
      {hiddenTipCount > 0 && <span class="rounded-md border border-amber/20 bg-black/25 px-2.5 py-1 text-[11px] font-black text-muted">他{hiddenTipCount}件</span>}
    </div>
  )}

  {!compact && (
    <p class="mt-4 flex-1 text-sm leading-7 text-muted">
      {venue.beginnerOneLine || venue.currentUseNote || venue.beginnerNote}
    </p>
  )}

  <a class="gothic-button focus-ring mt-5 inline-flex min-h-11 items-center justify-center rounded-md px-4 py-2 text-sm font-black transition" href={`/venues/${venue.slug}`}>
    詳細を見る
  </a>
</article>
