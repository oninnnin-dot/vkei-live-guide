---
import type { Venue } from '@/types';

interface Props {
  venue: Venue;
  compact?: boolean;
}

const { venue, compact = false } = Astro.props;

const scaleLabel = {
  small: '小箱',
  'small-mid': '小〜中箱',
  mid: '中箱',
  large: '大箱',
  unknown: '規模要確認',
}[venue.venueScale ?? 'unknown'];

const typeLabel = {
  small_livehouse: '小箱ライブハウス',
  mid_livehouse: '中箱ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '要確認',
}[venue.venueType ?? 'unknown'];

const affinityLabel = {
  high: 'V系向き高',
  medium: 'V系向き中',
  low: 'V系向き低',
  unknown: 'V系向き要確認',
}[venue.vkeiAffinity ?? 'unknown'];

const confidenceLabel = {
  verified: '公式確認済み',
  partially_verified: '一部確認',
  social_only: 'SNS由来',
  verified_or_historical: '履歴確認済み',
  unknown: '要確認',
}[venue.sourceConfidence ?? 'unknown'];

const badges = [
  typeLabel,
  scaleLabel,
  affinityLabel,
  venue.minorVkeiFriendly ? 'マイナーV系向き' : '',
  venue.soloFriendly >= 4 ? 'ぼっち参戦向き' : '',
  venue.lockerRisk >= 4 ? 'ロッカー注意' : '',
  venue.returnDifficulty >= 4 ? '終演後注意' : '',
].filter(Boolean);

const visibleTipTags = (venue.tipTags ?? []).slice(0, 3);
const hiddenTipCount = Math.max((venue.tipTags ?? []).length - visibleTipTags.length, 0);

const accessLabel = venue.station
  ? `${venue.station}${typeof venue.walkMinutes === 'number' ? ` / 徒歩目安 ${venue.walkMinutes}分` : ' / 徒歩目安 要確認'}`
  : '最寄り駅 要確認';

const sourceNotesText = Array.isArray(venue.sourceNotes)
  ? venue.sourceNotes.join(' ')
  : String(venue.sourceNotes ?? '');
---

<article class="rounded-2xl border border-white/10 bg-zinc-950/80 p-4 shadow-lg shadow-black/30">
  <div class="flex flex-wrap items-center gap-2">
    <span class="rounded-full bg-fuchsia-500/15 px-3 py-1 text-xs font-bold text-fuchsia-200">
      {venue.area ?? venue.prefecture ?? 'エリア要確認'}
    </span>

    {venue.archiveOnly && (
      <span class="rounded-full bg-amber-500/15 px-3 py-1 text-xs font-bold text-amber-200">
        閉館アーカイブ
      </span>
    )}
  </div>

  <h3 class="mt-3 text-xl font-black text-white">
    {venue.name}
  </h3>

  <p class="mt-2 text-sm text-zinc-300">
    最寄り: {accessLabel}
  </p>

  <div class="mt-4 flex flex-wrap gap-2">
    {badges.map((badge) => (
      <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-1 text-xs text-zinc-200">
        {badge}
      </span>
    ))}
  </div>

  {visibleTipTags.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {visibleTipTags.map((tag) => (
        <span class="rounded-full bg-purple-500/15 px-2.5 py-1 text-xs text-purple-100">
          {tag}
        </span>
      ))}
      {hiddenTipCount > 0 && (
        <span class="rounded-full bg-white/10 px-2.5 py-1 text-xs text-zinc-200">
          +{hiddenTipCount}
        </span>
      )}
    </div>
  )}

  {!compact && (
    <dl class="mt-4 grid grid-cols-2 gap-3 text-sm">
      <div>
        <dt class="text-xs text-zinc-500">会場種別</dt>
        <dd class="mt-1 font-semibold text-zinc-200">{typeLabel}</dd>
      </div>
      <div>
        <dt class="text-xs text-zinc-500">規模</dt>
        <dd class="mt-1 font-semibold text-zinc-200">{scaleLabel}</dd>
      </div>
      <div>
        <dt class="text-xs text-zinc-500">V系向き度</dt>
        <dd class="mt-1 font-semibold text-zinc-200">{affinityLabel}</dd>
      </div>
      <div>
        <dt class="text-xs text-zinc-500">情報確度</dt>
        <dd class="mt-1 font-semibold text-zinc-200">{confidenceLabel}</dd>
      </div>
    </dl>
  )}

  {!compact && (venue.currentUseNote || venue.beginnerNote) && (
    <p class="mt-4 text-sm leading-6 text-zinc-300">
      {venue.currentUseNote || venue.beginnerNote}
    </p>
  )}

  {compact && sourceNotesText && (
    <p class="mt-4 text-sm leading-6 text-zinc-400">
      {sourceNotesText}
    </p>
  )}

  <a
    href={`/venues/${venue.slug}`}
    class="mt-5 inline-flex min-h-11 w-full items-center justify-center rounded-full bg-fuchsia-500 px-4 py-2 text-sm font-bold text-white transition hover:bg-fuchsia-400"
  >
    詳細を見る
  </a>
</article>
