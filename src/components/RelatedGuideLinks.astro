---
interface GuideLink {
  href: string;
  title: string;
  text: string;
}

interface Props {
  title?: string;
  links?: GuideLink[];
}

const {
  title = 'あわせて確認したい実用ガイド',
  links = [
    { href: '/v-kei-live-belongings/', title: '推し活現場の持ち物チェックリスト', text: '当日バッグに入れるもの、駅やホテルに預けるものを分けて確認します。' },
    { href: '/small-livehouse-locker-cloak/', title: '小規模会場のロッカー・クローク完全ガイド', text: '会場ロッカー、クローク、駅ロッカーの使い分けを整理します。' },
    { href: '/livehouse-station-locker/', title: 'ライブ前に駅ロッカーを使うべき場面', text: 'キャリー、物販、良番、雨の日など、駅ロッカー先行が強い条件を確認します。' },
    { href: '/vkei-first-live-guide/', title: '初参戦ガイド', text: '整理番号、入場、ドリンク代、立ち位置、終演後の流れを確認します。' },
    { href: '/vkei-live-trip-cost/', title: '推し活遠征費の目安', text: 'チケット代以外の交通費、宿泊費、物販、ロッカー代を見落とさないようにします。' },
    { href: '/vkei-live-rainy-day/', title: '雨の日の現場対策', text: '濡れた荷物、傘、待機場所、帰りの移動を先に決めておきます。' },
    { href: '/vkei-live-after-show/', title: '終演後の帰り方・終電・宿泊判断', text: '終電、夜行バス、宿泊、タクシーの判断を終演前に整理します。' },
  ],
} = Astro.props;
---

<section class="container-navi py-8">
  <div class="mb-5">
    <p class="gothic-label">Related</p>
    <h2 class="font-classical mt-2 text-2xl font-black leading-tight text-mist">{title}</h2>
    <div class="ornament-line mt-3 max-w-xs"></div>
  </div>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {links.map((link) => (
      <a class="gothic-card focus-ring rounded-xl p-5 transition hover:-translate-y-0.5 hover:border-amber/60" href={link.href}>
        <span class="font-classical block text-lg font-black leading-snug text-mist">{link.title}</span>
        <span class="mt-2 block text-sm leading-7 text-muted">{link.text}</span>
      </a>
    ))}
  </div>
</section>
