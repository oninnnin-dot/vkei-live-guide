---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import NoticeBox from '@components/NoticeBox.astro';

const title = 'プライバシーポリシー｜推し活遠征ナビ';
const description = '推し活遠征ナビのプライバシーポリシー。アクセス解析、問い合わせ、外部リンク、Cookieの扱いについて説明します。';
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'プライバシーポリシー' }]} />
  <section class="container-navi py-8">
    <div class="max-w-3xl">
      <p class="gothic-label">Privacy</p>
      <h1 class="font-classical mt-3 text-3xl font-black leading-tight text-mist md:text-5xl">プライバシーポリシー</h1>
      <p class="mt-4 text-base leading-8 text-muted md:text-lg">
        当サイトは、推し活遠征に役立つ会場周辺情報と準備情報を提供する静的サイトです。個人を特定する情報を不要に収集しない運用を基本にします。
      </p>
    </div>
  </section>

  <section class="container-navi py-8">
    <article class="gothic-card rounded-xl p-5 md:p-8">
      <div class="grid gap-7 text-sm leading-7 text-muted md:text-base">
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">取得する可能性のある情報</h2>
          <p class="mt-3">問い合わせフォーム、口コミ投稿、メールを設置した場合、返信や確認に必要な範囲で名前、メールアドレス、問い合わせ内容、投稿内容を扱うことがあります。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">口コミ投稿について</h2>
          <p class="mt-3">投稿内容は承認制で確認し、個人が特定される情報やトラブルにつながる表現を除いたうえで、会場へ行く前後の実用メモとして公開する場合があります。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">アクセス解析について</h2>
          <p class="mt-3">今後、サイト改善のためにアクセス解析を導入する場合があります。その場合も、ページ改善や導線確認の目的で利用します。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">外部リンクについて</h2>
          <p class="mt-3">当サイトから移動する公式サイト、チケットサイト、施設案内サイトの情報管理は、各リンク先の方針に従います。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">Cookieについて</h2>
          <p class="mt-3">将来的に広告やアクセス解析を導入する場合、Cookie等を利用する可能性があります。導入時は必要な表記を整備します。</p>
        </section>
      </div>
    </article>
    <div class="mt-6">
      <NoticeBox title="公式情報確認のお願い" tone="warning">
        <p>公演情報、チケット状況、会場設備の最終判断は、公式サイト、主催者告知、当日案内を優先してください。</p>
      </NoticeBox>
    </div>
  </section>
</Layout>
