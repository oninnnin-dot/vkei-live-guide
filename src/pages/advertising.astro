---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import NoticeBox from '@components/NoticeBox.astro';

const title = '広告・アフィリエイト表記｜推し活遠征ナビ';
const description = '推し活遠征ナビの広告・アフィリエイト表記。一部のガイドやチェックリストに掲載する商品リンクと収益について説明します。';
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: '広告・アフィリエイト表記' }]} />
  <section class="container-navi py-8">
    <div class="max-w-3xl">
      <p class="gothic-label">Advertising</p>
      <h1 class="font-classical mt-3 text-3xl font-black leading-tight text-mist md:text-5xl">広告・アフィリエイト表記</h1>
      <p class="mt-4 text-base leading-8 text-muted md:text-lg">
        当サイトでは、推し活の遠征準備、持ち物、宿泊、移動、荷物預かり、雨の日対策、遠征費管理に関する広告リンクを掲載する場合があります。
      </p>
    </div>
  </section>

  <section class="container-navi py-8">
    <article class="gothic-card rounded-xl p-5 md:p-8">
      <div class="grid gap-7 text-sm leading-7 text-muted md:text-base">
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">広告リンクの方針</h2>
          <p class="mt-3">広告リンクを設置する場合でも、会場情報や当日の動き方の説明は、利用者が判断しやすいことを優先します。ジャンルに囚われず、ライブ、アイドル現場、アニメ・漫画関連イベント、舞台などの推し活全般で実用性があるものを扱います。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">紹介対象の例</h2>
          <p class="mt-3">モバイルバッテリー、充電ケーブル、ケーブル内蔵モバイルバッテリー、晴雨兼用の軽量折りたたみ傘、靴用防水スプレー、レインシューズカバー、汗拭きシート、制汗シート、冷却シート、使い捨てカイロ、ライブ用耳栓、音楽用イヤープラグ、衣類圧縮袋、トラベルポーチなどを想定しています。成人向けの商品やサービスは扱いません。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">商品リンクについて</h2>
          <p class="mt-3">持ち物や遠征グッズの商品リンクは、楽天アフィリエイトを中心に掲載します。もしもアフィリエイト経由の楽天市場の商品購入リンクを使用し、購入により当サイトに報酬が入る場合があります。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">口コミと広告の分離</h2>
          <p class="mt-3">利用者投稿やスポット候補は、広告とは分けて確認します。公開する情報は、会場へ行く前後の判断に役立つ内容へ要約し、広告リンクの有無で会場評価を変えません。</p>
        </section>
        <section>
          <h2 class="font-classical text-2xl font-black text-mist">公演情報との分離</h2>
          <p class="mt-3">当サイトは公演名、出演者、日程、チケット状況を集めるサイトではありません。最新の公演情報は公式サイトやチケットサイトで確認してください。</p>
        </section>
      </div>
    </article>
    <div class="mt-6">
      <NoticeBox title="現在の状態" tone="success">
        <p>現在、一部のガイドやチェックリストに商品リンクを掲載しています。これらは遠征準備に役立つアイテムを厳選しており、購入により当サイトが収益を得る場合があります。</p>
      </NoticeBox>
    </div>
  </section>
</Layout>
