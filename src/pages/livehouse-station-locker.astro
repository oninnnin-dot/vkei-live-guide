---
import SeoGuidePage from '@components/SeoGuidePage.astro';

const sections = [
  {
    title: '駅ロッカー先行が強い日',
    lead: '会場に着いてから荷物を考えると、整列や物販のタイミングとぶつかります。条件が重なる日は駅で先に身軽にします。',
    points: [
      'キャリーケースがある日は、会場へ向かう前に駅大型ロッカーやホテル預けを済ませる。',
      '良番の日は、入場直前にロッカーやクロークで迷わないことを優先する。',
      '物販で荷物が増える日は、買った後に戻れる駅ロッカーか、会場クロークの受付時間を先に見る。',
    ],
  },
  {
    title: '駅ロッカーを探す順番',
    lead: '大きな駅ほど便利ですが、休日やイベント日には埋まりやすくなります。探す順番を決めておくと焦りにくいです。',
    points: [
      'まず到着駅の改札内外を確認する。大型荷物があるなら大型対応を優先する。',
      '埋まっていたら、隣駅、ホテル、商業施設の荷物預かりを候補にする。',
      '帰りに取り出す方向も考える。終演後に逆方向へ戻るロッカーは時間を使いやすい。',
    ],
  },
  {
    title: '会場ロッカーと駅ロッカーの使い分け',
    lead: '会場ロッカーは近くて便利ですが、数やサイズ、使えるタイミングに左右されます。',
    points: [
      '荷物が小さい、整理番号が後方、終電に余裕がある日は会場ロッカーでも対応しやすい。',
      '荷物が大きい、初めての会場、雨、終電が近い日は駅ロッカーの方が安定しやすい。',
      '会場クロークがある場合も、公演ごとの受付時間と返却混雑を見て判断する。',
    ],
  },
];
---

<SeoGuidePage
  title="ライブ前に駅ロッカーを使うべき場面｜小箱V系ライブの荷物判断"
  description="ライブ前に駅ロッカーを使うべき条件を、キャリーケース、物販、良番、雨の日、終演後の移動で整理。小箱V系ライブの荷物判断に使えるガイドです。"
  pageTitle="ライブ前に駅ロッカーを使うべき場面"
  eyebrow="Station Locker"
  lead="駅ロッカーは、会場設備が読めない日ほど強い保険になります。荷物量、整理番号、天気、帰りの予定から使うべき場面を整理します。"
  sections={sections}
/>
