---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import NoticeBox from '@components/NoticeBox.astro';
import SectionTitle from '@components/SectionTitle.astro';
import venues from '@data/venues.json';
import type { Venue } from '@/types';

const title = '全国推し活会場マップ｜地域別の主要ライブハウス一覧';
const description = '全国のライブや推し活イベントで使われることがある会場を、地域・都道府県・会場種別・推し活向き度で整理した一覧です。公演情報やチケット状況は掲載しません。';
const regionOrder = ['東京', '神奈川', '関東', '北海道・東北', '甲信越・北陸', '東海', '関西', '中国・四国', '九州・沖縄'];
const activeVenues = (venues as Venue[])
  .filter((venue) => venue.status !== 'closed' && venue.showInVenueList && !venue.archiveOnly)
  .sort((a, b) => {
    const regionDiff = regionOrder.indexOf(a.region) - regionOrder.indexOf(b.region);
    if (regionDiff !== 0) return regionDiff;
    const prefDiff = a.prefecture.localeCompare(b.prefecture, 'ja');
    if (prefDiff !== 0) return prefDiff;
    return a.name.localeCompare(b.name, 'ja');
  });
const grouped = regionOrder
  .map((region) => ({
    region,
    venues: activeVenues.filter((venue) => venue.region === region),
  }))
  .filter((group) => group.venues.length > 0);
const typeLabel = {
  small_livehouse: '小規模ライブハウス',
  mid_livehouse: '中規模ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '要確認',
};
const affinityLabel = {
  high: '推し活向き高',
  medium: '推し活向き中',
  low: '推し活向き低',
  unknown: '要確認',
};
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: '会場攻略', href: '/venues' }, { label: '地域別一覧' }]} />
  <section class="container-navi py-8">
    <p class="gothic-label">Regions</p>
    <h1 class="font-classical mt-3 text-3xl font-black leading-tight text-mist md:text-5xl">全国推し活会場マップ</h1>
    <p class="mt-4 max-w-3xl text-base leading-8 text-muted md:text-lg">
      地域ごとに、ライブや推し活イベントで使われることがある会場を一覧表示します。会場名・地域・会場分類だけを扱い、公演詳細は公式へ誘導します。
    </p>
    <div class="mt-6">
      <NoticeBox title="公演情報は公式確認" tone="warning">
        <p>この会場一覧は、ライブや推し活イベントで使われることがある会場を整理したものです。公演情報、出演者、日程、チケット状況は掲載していません。最新の公演情報は必ず公式サイト・チケットサイト・会場公式スケジュールで確認してください。</p>
      </NoticeBox>
    </div>
  </section>
  <section class="container-navi pb-12">
    {grouped.map((group) => (
      <div class="py-6">
        <SectionTitle title={group.region} lead={`${group.venues.length}件の現役会場を表示しています。`} />
        <div class="grid gap-3">
          {group.venues.map((venue) => (
            <article class="gothic-card rounded-xl p-4">
              <div class="grid gap-3 md:grid-cols-[1fr_auto] md:items-center">
                <div>
                  <p class="gothic-label">{venue.prefecture} / {venue.area}</p>
                  <h2 class="font-classical mt-1 text-lg font-black text-mist">{venue.name}</h2>
                </div>
                <a class="gothic-button focus-ring inline-flex min-h-10 items-center justify-center rounded-md px-4 text-sm font-black transition" href={`/venues/${venue.slug}`}>
                  詳細ページ
                </a>
              </div>
              <dl class="mt-4 grid gap-2 text-sm md:grid-cols-3">
                <div class="rounded-md border border-amber/20 bg-black/25 px-3 py-2">
                  <dt class="text-muted">会場種別</dt>
                  <dd class="mt-1 font-black text-mist">{typeLabel[venue.venueType] ?? '要確認'}</dd>
                </div>
                <div class="rounded-md border border-amber/20 bg-black/25 px-3 py-2">
                  <dt class="text-muted">推し活向き度</dt>
                  <dd class="mt-1 font-black text-mist">{affinityLabel[venue.vkeiAffinity] ?? '要確認'}</dd>
                </div>
                <div class="rounded-md border border-amber/20 bg-black/25 px-3 py-2">
                  <dt class="text-muted">小規模現場向き</dt>
                  <dd class="mt-1 font-black text-mist">{venue.minorVkeiFriendly ? '向き' : '要確認'}</dd>
                </div>
              </dl>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>
