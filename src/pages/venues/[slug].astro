---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import InfoBlock from '@components/InfoBlock.astro';
import LinkCard from '@components/LinkCard.astro';
import NoticeBox from '@components/NoticeBox.astro';
import SectionTitle from '@components/SectionTitle.astro';
import venues from '@data/venues.json';
import type { Venue } from '@/types';

export function getStaticPaths() {
  return (venues as Venue[]).map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

interface Props {
  venue: Venue;
}

const { venue } = Astro.props;

const scaleLabel = {
  small: '小箱',
  'small-mid': '小〜中箱',
  mid: '中箱',
  large: '大箱',
  unknown: '規模要確認',
}[venue.venueScale];

const typeLabel = {
  small_livehouse: '小箱ライブハウス',
  mid_livehouse: '中箱ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '要確認',
}[venue.venueType ?? 'unknown'];

const affinityLabel = {
  high: 'V系利用傾向: 高',
  medium: 'V系利用傾向: 中',
  low: 'V系利用傾向: 低',
  unknown: 'V系利用傾向: 要確認',
}[venue.vkeiAffinity];

const confidenceLabel = {
  verified: '公式・一次情報確認済み',
  partially_verified: '一部確認済み',
  social_only: 'SNS言及ベース',
  verified_or_historical: '履歴情報として確認',
  unknown: '要確認',
}[venue.sourceConfidence ?? 'unknown'];

const sourceTypeLabel = {
  official: '公式',
  ticket_site: 'チケットサイト',
  ticket_site_or_user_list: 'チケットサイトまたは手動リスト',
  social: 'SNS',
  mixed: '複数ソース',
  unknown: '要確認',
}[venue.sourceType ?? 'unknown'];

const vkeiUseTypeLabel = {
  minor_vkei: '若手・マイナーV系',
  vkei_regular: 'V系定期利用候補',
  vkei_occasional: 'V系公演あり候補',
  release_event: 'リリースイベント枠',
  large_scale: '大規模公演枠',
  copy_band: 'コピー/関連イベント枠',
  related_event: '関連イベント枠',
  unknown: '要確認',
}[venue.vkeiUseType ?? 'unknown'];

const sourceNotes = Array.isArray(venue.sourceNotes)
  ? venue.sourceNotes
  : venue.sourceNotes
    ? [String(venue.sourceNotes)]
    : [];
const warnings = Array.isArray(venue.warnings) ? venue.warnings : [];
const preCheckItems = Array.isArray(venue.preCheckItems) ? venue.preCheckItems : [];
const tips = Array.isArray(venue.tips) ? venue.tips : [];
const tipTags = Array.isArray(venue.tipTags) ? venue.tipTags : [];
const ticketSearchLinks = Array.isArray(venue.ticketSearchLinks) ? venue.ticketSearchLinks : [];
const sourceNotesText = sourceNotes.join(' ');
const equipmentNeedsCheck =
  sourceNotesText.includes('設備情報は要確認') ||
  sourceNotesText.includes('公式URL・設備情報は要確認') ||
  ['partially_verified', 'social_only', 'unknown'].includes(venue.sourceConfidence ?? 'unknown');

const accessText = venue.station
  ? `${venue.station}${typeof venue.walkMinutes === 'number' ? `から徒歩目安 ${venue.walkMinutes}分` : 'からの徒歩目安は要確認'}`
  : '最寄り駅は要確認';

const title = `${venue.name}｜会場情報・ロッカー/クローク確認メモ`;
const description = `${venue.name}の会場分類、所在地、最寄り駅、ロッカー・クローク・荷物・待機・帰り道の確認メモを整理。公演情報は公式サイト・チケットサイトで確認してください。`;
const needsSourceWarning = venue.sourceConfidence === 'social_only' || venue.sourceConfidence === 'unknown';

const factRows = [
  ['会場名', venue.name],
  ['地域', venue.region],
  ['都道府県/エリア', [venue.prefecture, venue.area].filter(Boolean).join(' / ')],
  ['最寄り', accessText],
  ['会場種別', typeLabel],
  ['規模分類', scaleLabel],
  ['V系利用分類', `${affinityLabel} / ${vkeiUseTypeLabel}`],
  ['若手・マイナーV系候補', venue.minorVkeiFriendly ? '候補として登録' : '専用会場としては扱わない'],
  ['公式URL', venue.officialUrl ? '登録あり' : '未登録'],
  ['最終確認日', venue.lastVerifiedAt || '未登録'],
];

const equipmentBlocks = [
  ['ロッカー情報', venue.lockerNote],
  ['ロッカー運用メモ', venue.lockerStrategy],
  ['クローク運用メモ', venue.cloakStrategy],
  ['荷物メモ', venue.baggageNote || venue.baggageStrategy],
].filter(([, text]) => Boolean(text));

const visitMemoBlocks = [
  ['入場・整理番号', venue.entryStrategy],
  ['ドリンク代・現金', venue.drinkStrategy || venue.cashNote],
  ['物販後の荷物', venue.merchStrategy],
  ['開場前の待機', venue.waitingNote],
  ['周辺コンビニ', venue.convenienceNote],
  ['雨の日', venue.rainNote],
  ['終演後の帰り', venue.returnNote || venue.returnStrategy],
  ['夜の帰り道', venue.nightSafetyNote],
  ['ぼっち参戦', venue.soloStrategy || venue.soloNote],
  ['初参戦メモ', venue.beginnerStrategy || venue.beginnerNote],
  ['トイレ', venue.restroomNote],
  ['電波', venue.signalNote],
  ['階段・通路', venue.stairsNote],
  ['周辺環境', venue.neighborhoodNote],
  ['撮影可否', venue.photographyNote],
  ['再入場', venue.reentryNote],
].filter(([, text]) => Boolean(text));

const relatedLinks = [
  { title: 'V系ライブハウス参戦前に知っておきたい豆知識', description: '荷物、ロッカー、ドリンク代、整理番号、撮影ルール、終演後の動きを確認できます。', href: '/guides/livehouse-tips', cta: '読む' },
  { title: '小さいライブハウスのV系ライブ初参戦ガイド', description: '小箱での荷物、立ち位置、整理番号、ロッカー、帰り方を確認できます。', href: '/guides/small-venue', cta: '読む' },
  { title: '持ち物チェックリスト', description: 'チケット、身分証、モバイルバッテリー、雨具、物販用バッグを確認できます。', href: '/guides/belongings', cta: '確認する' },
  { title: '遠征費シミュレーター', description: 'チケット代、交通費、ホテル代、物販予算を入力して合計を確認できます。', href: '/tools/budget', cta: '計算する' },
];
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: '会場攻略', href: '/venues' }, { label: venue.name }]} />

  <section class="container-navi py-8">
    <div class="max-w-4xl">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan">{venue.area}</p>
      <h1 class="mt-3 text-3xl font-black leading-tight text-white md:text-5xl">{venue.name}</h1>
      <p class="mt-4 text-base leading-8 text-muted md:text-lg">
        {accessText}。このページでは、会場名・地域・会場分類・設備確認メモを扱います。ロッカーやクロークなど未確認の設備は断定せず、確認が必要な項目として表示します。
      </p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="rounded-full border border-violet/45 bg-violet/10 px-3 py-1 text-xs font-black text-mist">{typeLabel}</span>
        <span class="rounded-full border border-violet/45 bg-violet/10 px-3 py-1 text-xs font-black text-mist">{scaleLabel}</span>
        <span class="rounded-full border border-violet/45 bg-violet/10 px-3 py-1 text-xs font-black text-mist">{affinityLabel}</span>
        <span class="rounded-full border border-violet/45 bg-violet/10 px-3 py-1 text-xs font-black text-mist">情報確度: {confidenceLabel}</span>
        {equipmentNeedsCheck && <span class="rounded-full border border-amber/60 bg-amber/10 px-3 py-1 text-xs font-black text-mist">設備情報は要確認</span>}
        {venue.archiveOnly && <span class="rounded-full border border-amber/60 bg-amber/10 px-3 py-1 text-xs font-black text-mist">閉館アーカイブ</span>}
      </div>
    </div>

    <div class="mt-8">
      <NoticeBox title="公演情報は公式確認" tone="warning">
        <p>公演日・出演者・開場/開演時間・チケット状況・入場順・ドリンク代・物販ルールは、公演や時期によって変わる場合があります。最新情報は必ず公式サイト、チケットサイト、会場公式スケジュール、主催者告知、当日案内で確認してください。</p>
      </NoticeBox>
    </div>

    {needsSourceWarning && (
      <div class="mt-4">
        <NoticeBox title="要確認情報" tone="warning">
          <p>この会場情報は公式確認が十分ではない候補情報を含みます。会場公式・チケットサイトで確認が完了するまで、掲載内容は要確認として扱います。</p>
        </NoticeBox>
      </div>
    )}

    {venue.archiveOnly && (
      <div class="mt-4">
        <NoticeBox title="アーカイブ扱いの会場" tone="warning">
          <p>この会場は現役会場一覧には表示しません。過去会場・閉館済み会場として記録用に掲載しています。</p>
        </NoticeBox>
      </div>
    )}
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="確認済みとして扱う基本情報" lead="抽象スコアではなく、登録している事実項目と確認状況を表示します。" />
    <div class="rounded-lg border border-line bg-panel p-5 shadow-glow">
      <dl class="grid gap-3 text-sm md:grid-cols-2">
        {factRows.map(([label, value]) => (
          <div class="rounded-md border border-line bg-black/20 px-3 py-3">
            <dt class="text-muted">{label}</dt>
            <dd class="mt-1 font-black text-white">{value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="情報の確度と確認範囲" lead="設備や運用は変わりやすいため、未確認の項目は未確認として扱います。" />
    <div class="grid gap-4 md:grid-cols-2">
      <InfoBlock title="sourceConfidence" text={`${venue.sourceConfidence}（${confidenceLabel}）`} />
      <InfoBlock title="sourceType" text={`${venue.sourceType}（${sourceTypeLabel}）`} />
      <InfoBlock title="sourceNotes" text={sourceNotes.length ? sourceNotes.join(' / ') : '未登録'} />
      <InfoBlock title="sourceMemo" text={venue.sourceMemo || '未登録'} />
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="ロッカー・クローク・荷物の確認メモ" lead="ここは数値の注意度ではなく、登録済みの事実メモと未確認状態を表示します。" />
    {equipmentNeedsCheck && (
      <div class="mb-4">
        <NoticeBox title="設備情報は要確認" tone="warning">
          <p>ロッカー、クローク、ドリンク代、再入場、撮影可否などの設備・運用情報は、公式確認済みでない場合があります。会場公式、主催者告知、チケットサイト、当日案内で確認してください。</p>
        </NoticeBox>
      </div>
    )}
    <div class="grid gap-4 md:grid-cols-2">
      {equipmentBlocks.map(([label, text]) => <InfoBlock title={label} text={text} />)}
    </div>
  </section>

  {preCheckItems.length > 0 && (
    <section class="container-navi py-8">
      <SectionTitle title="参戦前に公式で確認すること" />
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {preCheckItems.map((item) => (
          <div class="rounded-lg border border-line bg-panel p-4 text-sm font-black text-white shadow-glow">{item}</div>
        ))}
      </div>
    </section>
  )}

  {tipTags.length > 0 && (
    <section class="container-navi py-8">
      <SectionTitle title="この会場の注意タグ" lead="タグは検索用の分類です。設備の有無を断定するものではありません。" />
      <div class="flex flex-wrap gap-2">
        {tipTags.map((tag) => <span class="rounded-full border border-cyan/35 bg-cyan/10 px-3 py-1 text-xs font-black text-mist">{tag}</span>)}
      </div>
    </section>
  )}

  <section class="container-navi py-8">
    <SectionTitle title="会場別メモ" lead="公式・当日案内で変わる可能性がある項目は、断定せず確認メモとして扱います。" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {visitMemoBlocks.map(([label, text]) => <InfoBlock title={label} text={text} />)}
    </div>
  </section>

  {tips.length > 0 && (
    <section class="container-navi py-8">
      <SectionTitle title="豆知識・事前知識" lead="他サイト文章のコピーではなく、参戦準備用の要点として整理しています。" />
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {tips.map((tip) => (
          <article class="rounded-lg border border-line bg-panel p-5 shadow-glow">
            <p class="text-xs font-black uppercase tracking-[0.16em] text-cyan">{tip.category} / {tip.confidence}</p>
            <h2 class="mt-2 text-lg font-black text-white">{tip.title}</h2>
            <p class="mt-3 text-sm leading-7 text-muted">{tip.body}</p>
            <p class="mt-4 text-xs text-muted">sourceType: {tip.sourceType} / 確認日: {tip.lastVerifiedAt}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  {(warnings.length > 0 || sourceNotes.length > 0) && (
    <section class="container-navi py-8">
      <SectionTitle title="注意書き" />
      <div class="rounded-lg border border-line bg-panel p-5 shadow-glow">
        <div class="space-y-2 text-sm leading-7 text-muted">
          {warnings.map((warning) => <p>{warning}</p>)}
          {sourceNotes.map((note) => <p>{note}</p>)}
        </div>
      </div>
    </section>
  )}

  <section class="container-navi py-8">
    <SectionTitle title="公式・検索リンク" lead="公演情報、出演者、日程、チケット状況はリンク先で確認してください。" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {venue.officialUrl && <LinkCard title={`${venue.name} 公式ページ`} description="会場公式ページを開きます。設備・アクセス・スケジュールは公式情報を優先してください。" href={venue.officialUrl} cta="公式を見る" />}
      {ticketSearchLinks.map((link) => (
        <LinkCard title={link.label} description="チケットサイト側で最新の公演情報を確認してください。当サイトでは公演情報を転載しません。" href={link.url} cta="公式で確認" />
      ))}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="関連記事" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {relatedLinks.map((link) => <LinkCard {...link} />)}
    </div>
  </section>
</Layout>
