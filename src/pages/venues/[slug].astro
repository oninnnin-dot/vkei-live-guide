---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import LinkCard from '@components/LinkCard.astro';
import NoticeBox from '@components/NoticeBox.astro';
import SectionTitle from '@components/SectionTitle.astro';
import venues from '@data/venues.json';
import type { Venue } from '@/types';

export function getStaticPaths() {
  return (venues as Venue[]).map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

interface Props {
  venue: Venue;
}

const { venue } = Astro.props;

const scaleLabel = {
  small: '小箱',
  'small-mid': '小〜中箱',
  mid: '中箱',
  large: '大箱',
  unknown: '規模要確認',
}[venue.venueScale];

const typeLabel = {
  small_livehouse: '小箱ライブハウス',
  mid_livehouse: '中箱ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '要確認',
}[venue.venueType ?? 'unknown'];

const confidenceLabel = {
  verified: '公式・一次情報確認済み',
  partially_verified: '一部確認済み',
  social_only: 'SNS言及ベース',
  verified_or_historical: '履歴情報として確認',
  unknown: '要確認',
}[venue.sourceConfidence ?? 'unknown'];

const factSourceTypeLabel = {
  official: '公式',
  ticket_site: 'チケットサイト',
  ticket_site_or_user_list: 'チケットサイトまたは手動リスト',
  blog: '個人ブログ/体験記事',
  venue_database: '会場情報サイト',
  review_site: 'レビューサイト',
  social: 'SNS',
  mixed: '複数ソース',
  unknown: '要確認',
};

const lockerStatusLabel = {
  none: 'なし',
  limited: '少なめ',
  available: 'あり',
  unknown: '要確認',
}[venue.lockerProfile?.status ?? 'unknown'];

const cloakStatusLabel = {
  available: 'あり',
  sometimes: '公演ごと',
  none: 'なし',
  unknown: '要確認',
}[venue.cloakProfile?.status ?? 'unknown'];

const accessText = venue.station
  ? `${venue.station}${typeof venue.walkMinutes === 'number' ? `から徒歩目安 ${venue.walkMinutes}分` : 'からの徒歩目安は要確認'}`
  : '最寄り駅は要確認';

const sourceNotes = Array.isArray(venue.sourceNotes) ? venue.sourceNotes : [];
const officialFacts = (venue.factChecks ?? []).filter((fact) => fact.sourceType === 'official');
const communityFacts = (venue.factChecks ?? []).filter((fact) => fact.sourceType !== 'official');
const sourceLinks = venue.sourceLinks ?? [];
const blogSignals = venue.blogSignals ?? [];
const venueComments = venue.venueComments ?? [];
const summaryPoints = venue.practicalSummary?.points ?? [];
const title = `${venue.name}｜30秒結論・荷物/ロッカー攻略`;
const description = `${venue.name}の当日の動き方、荷物別判断、ロッカー・クローク、物販後、終演後の動きを整理。公演情報は転載せず公式へ誘導します。`;

const actionBlocks = [
  ['入場前', venue.arrivalStrategy],
  ['整列・入場', venue.entryStrategyPlain],
  ['物販後', venue.merchBaggageStrategy],
  ['終演後', venue.afterShowStrategy],
].filter(([, text]) => Boolean(text));

const warningBlocks = [
  ['良番なら', venue.goodNumberWarning],
  ['キャリーありなら', venue.carryCaseWarning],
  ['フロア荷物', venue.floorBaggageWarning],
  ['雨の日', venue.badWeatherNote],
  ['駅ロッカー', venue.stationLockerNote],
].filter(([, text]) => Boolean(text));

const fieldBlocks = [
  ['時間調整', venue.timeKillingNote || venue.waitingNote],
  ['コンビニ・飲み物', venue.convenienceNote],
  ['会場前待機', venue.waitingNote],
  ['夜の帰り道', venue.nightSafetyNote],
  ['ロッカー代替', venue.lockerAlternativeNote || venue.stationLockerNote],
  ['雨の日', venue.badWeatherNote || venue.rainNote],
].filter(([, text]) => Boolean(text));

const relatedLinks = [
  { title: 'V系ライブハウス参戦前に知っておきたい豆知識', description: '荷物、ロッカー、ドリンク代、整理番号、撮影ルール、終演後の動きを確認できます。', href: '/guides/livehouse-tips', cta: '読む' },
  { title: '小さいライブハウスのV系ライブ初参戦ガイド', description: '小箱での荷物、立ち位置、整理番号、ロッカー、帰り方を確認できます。', href: '/guides/small-venue', cta: '読む' },
  { title: '持ち物チェックリスト', description: 'チケット、身分証、モバイルバッテリー、雨具、物販用バッグを確認できます。', href: '/guides/belongings', cta: '確認する' },
  { title: '遠征費シミュレーター', description: 'チケット代、交通費、ホテル代、物販予算を入力して合計を確認できます。', href: '/tools/budget', cta: '計算する' },
];
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: '会場攻略', href: '/venues' }, { label: venue.name }]} />

  <section class="container-navi py-8">
    <div class="gothic-panel rounded-xl p-5 md:p-8">
      <p class="gothic-label">{venue.area} / {typeLabel}</p>
      <h1 class="font-classical mt-4 text-3xl font-black leading-tight text-mist md:text-5xl">{venue.name}</h1>
      <p class="mt-4 text-base leading-8 text-muted md:text-lg">{accessText}。公演情報ではなく、当日の荷物・入場・物販後・終演後の動き方を整理します。</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">{scaleLabel}</span>
        <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">情報確度: {confidenceLabel}</span>
        <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">ロッカー危険度 {venue.lockerProfile?.riskLevel ?? 3}/5</span>
        <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">クローク {cloakStatusLabel}</span>
      </div>
    </div>

    <div class="mt-5">
      <NoticeBox title="公演情報は転載しません" tone="warning">
        <p>公演日・出演者・開場/開演時間・チケット状況・物販ルールは掲載しません。最新情報は公式サイト、チケットサイト、会場公式スケジュール、主催者告知、当日案内で確認してください。</p>
      </NoticeBox>
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle eyebrow="Quick Answer" title="30秒結論" lead="まずここだけ読めば、当日どう動くか決められます。" />
    <div class="gothic-card rounded-xl p-5 md:p-6">
      <p class="font-classical pt-2 text-2xl font-black leading-snug text-mist">{venue.practicalSummary?.headline}</p>
      <ul class="mt-5 grid gap-3 md:grid-cols-2">
        {summaryPoints.map((point) => (
          <li class="rounded-md border border-amber/20 bg-black/25 p-3 text-sm font-bold leading-7 text-muted">{point}</li>
        ))}
      </ul>
    </div>
  </section>

  {venue.preCheckItems?.length > 0 && (
    <section class="container-navi py-8">
      <SectionTitle title="入場前チェック要件" lead="この会場で詰みやすいところを、入場前に潰します。" />
      <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        {venue.preCheckItems.map((item) => (
          <div class="gothic-card rounded-xl p-4">
            <p class="text-sm font-black leading-7 text-mist">{item}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {venueComments.length > 0 && (
    <section class="container-navi py-8">
      <SectionTitle title="この会場の実用コメント" lead="公式情報・会場DB・個人ブログをもとに、当日の動きへ変換したコメントです。" />
      <div class="grid gap-4 md:grid-cols-2">
        {venueComments.map((item) => (
          <article class="gothic-card rounded-xl p-5">
            <p class="gothic-label pt-2">{item.category} / {item.confidence}</p>
            <h2 class="font-classical mt-2 text-xl font-black leading-snug text-mist">{item.title}</h2>
            <p class="mt-3 text-sm leading-7 text-muted">{item.comment}</p>
            <p class="mt-4 rounded-md border border-amber/20 bg-black/25 p-3 text-sm font-black leading-7 text-mist">{item.action}</p>
            <p class="mt-3 text-xs leading-6 text-muted">
              出典: <a class="text-amber underline-offset-4 hover:underline" href={item.sourceUrl} target="_blank" rel="noopener noreferrer">{item.sourceName}</a>
              {' '} / {item.sourceType} / 確認日: {item.checkedAt}
            </p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="container-navi py-8">
    <SectionTitle title="荷物・ロッカー結論" lead="荷物で詰むかどうかを先に潰します。" />
    <div class="grid gap-5 lg:grid-cols-[1fr_0.9fr]">
      <article class="gothic-card rounded-xl p-5">
        <p class="gothic-label pt-2">Locker</p>
        <h2 class="font-classical mt-2 text-xl font-black text-mist">ロッカー: {lockerStatusLabel}</h2>
        <p class="mt-3 text-sm leading-7 text-muted">{venue.lockerProfile?.summary}</p>
        <p class="mt-4 rounded-md border border-amber/20 bg-black/25 p-3 text-sm font-black leading-7 text-mist">{venue.lockerProfile?.bestMove}</p>
        <dl class="mt-4 grid gap-2 text-sm">
          <div class="grid grid-cols-[auto_1fr] gap-3"><dt class="text-muted">危険度</dt><dd class="text-right font-black text-mist">{venue.lockerProfile?.riskLevel ?? 3}/5</dd></div>
          <div class="grid grid-cols-[auto_1fr] gap-3"><dt class="text-muted">タイミング</dt><dd class="text-right font-black text-mist">{venue.lockerProfile?.timing}</dd></div>
          <div class="grid grid-cols-[auto_1fr] gap-3"><dt class="text-muted">小銭</dt><dd class="text-right font-black text-mist">{venue.lockerProfile?.coinNote}</dd></div>
        </dl>
      </article>

      <article class="gothic-card rounded-xl p-5">
        <p class="gothic-label pt-2">Cloak</p>
        <h2 class="font-classical mt-2 text-xl font-black text-mist">クローク: {cloakStatusLabel}</h2>
        <p class="mt-3 text-sm leading-7 text-muted">{venue.cloakProfile?.summary}</p>
        <p class="mt-4 rounded-md border border-amber/20 bg-black/25 p-3 text-sm font-black leading-7 text-mist">{venue.cloakProfile?.bestMove}</p>
        <dl class="mt-4 grid gap-2 text-sm">
          <div class="grid grid-cols-[auto_1fr] gap-3"><dt class="text-muted">料金</dt><dd class="text-right font-black text-mist">{venue.cloakProfile?.priceNote}</dd></div>
          <div class="grid grid-cols-[auto_1fr] gap-3"><dt class="text-muted">受付</dt><dd class="text-right font-black text-mist">{venue.cloakProfile?.timing}</dd></div>
          <div class="grid grid-cols-[auto_1fr] gap-3"><dt class="text-muted">袋</dt><dd class="text-right font-black text-mist">{venue.cloakProfile?.bagTypeNote}</dd></div>
        </dl>
      </article>
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="荷物別の動き方" lead="自分の荷物量に合わせて決めます。" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {[
        ['小バッグ', venue.baggageDecision?.tinyBag],
        ['リュック', venue.baggageDecision?.backpack],
        ['キャリー', venue.baggageDecision?.suitcase],
        ['物販後', venue.baggageDecision?.afterMerch],
        ['良番', venue.baggageDecision?.goodTicketNumber],
      ].map(([label, text]) => (
        <article class="gothic-card rounded-xl p-4">
          <p class="gothic-label pt-2">{label}</p>
          <p class="mt-3 text-sm font-bold leading-7 text-muted">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="当日の動き方" lead="確認推奨で終わらせず、どう動くかを先に書きます。" />
    <div class="grid gap-4 md:grid-cols-2">
      {actionBlocks.map(([label, text]) => (
        <article class="gothic-card rounded-xl p-5">
          <p class="gothic-label pt-2">{label}</p>
          <p class="mt-3 text-sm font-bold leading-7 text-muted">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="周辺・待機・帰り" lead="ロッカーだけでなく、開場前の逃げ場と終演後の戻り方まで見ます。" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {fieldBlocks.map(([label, text]) => (
        <article class="gothic-card rounded-xl p-5">
          <p class="gothic-label pt-2">{label}</p>
          <p class="mt-3 text-sm font-bold leading-7 text-muted">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="詰みやすいポイント" lead="良番、雨、キャリー、終電など、当日に焦りやすいところ。" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {warningBlocks.map(([label, text]) => (
        <article class="rounded-xl border border-amber/25 bg-violet/20 p-4">
          <p class="font-classical font-black text-mist">{label}</p>
          <p class="mt-2 text-sm leading-7 text-muted">{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="ぼっち参戦・初参戦メモ" />
    <div class="grid gap-4 md:grid-cols-2">
      <article class="gothic-card rounded-xl p-5">
        <p class="gothic-label pt-2">Solo</p>
        <p class="mt-3 text-sm font-bold leading-7 text-muted">{venue.soloOneLine}</p>
      </article>
      <article class="gothic-card rounded-xl p-5">
        <p class="gothic-label pt-2">Beginner</p>
        <p class="mt-3 text-sm font-bold leading-7 text-muted">{venue.beginnerOneLine}</p>
      </article>
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="情報ソース" lead="公式情報と個人ブログ・会場情報サイト由来の要確認メモを分けています。文章コピーはしていません。" />
    <div class="grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="gothic-card rounded-xl p-5">
        <p class="gothic-label pt-2">Source Links</p>
        <div class="mt-4 grid gap-3">
          {sourceLinks.length > 0 ? sourceLinks.map((source) => (
            <a class="rounded-md border border-amber/20 bg-black/25 p-3 text-sm leading-7 text-muted transition hover:border-amber/55 hover:text-amber" href={source.url || '#'} target={source.url ? '_blank' : undefined} rel={source.url ? 'noopener noreferrer' : undefined}>
              <span class="font-black text-mist">{source.label}</span><br />
              <span>{source.type} / {source.checkedAt}</span>
            </a>
          )) : <p class="text-sm leading-7 text-muted">参照元は未登録です。</p>}
        </div>
      </div>

      <div class="gothic-card rounded-xl p-5">
        <p class="gothic-label pt-2">Signals</p>
        <div class="mt-4 grid gap-3">
          {blogSignals.length > 0 ? blogSignals.map((signal) => (
            <article class="rounded-md border border-amber/20 bg-black/25 p-3">
              <p class="text-xs font-black text-amber">{signal.topic} / {signal.sourceType} / {signal.confidence}</p>
              <p class="mt-2 text-sm leading-7 text-muted">{signal.summary}</p>
              <p class="mt-2 text-xs leading-6 text-muted">出典: <a class="text-amber underline-offset-4 hover:underline" href={signal.sourceUrl} target="_blank" rel="noopener noreferrer">{signal.sourceName}</a> / {signal.copyrightNote}</p>
            </article>
          )) : <p class="text-sm leading-7 text-muted">個人ブログ・参戦レポ由来の要確認メモは未登録です。</p>}
        </div>
      </div>
    </div>
    <p class="mt-4 rounded-md border border-amber/25 bg-black/25 p-4 text-sm leading-7 text-muted">{venue.infoFreshnessWarning}</p>
  </section>

  {(officialFacts.length > 0 || communityFacts.length > 0) && (
    <section class="container-navi py-8">
      <SectionTitle title="登録済みメモ一覧" lead="細かい公式事実・要確認メモです。最終判断は公式と当日案内を優先してください。" />
      <div class="grid gap-4 md:grid-cols-2">
        {[...officialFacts, ...communityFacts].map((fact) => (
          <article class="gothic-card rounded-xl p-4">
            <p class="gothic-label pt-2">{fact.sourceType === 'official' ? 'Official' : 'Check'}</p>
            <h2 class="font-classical mt-2 text-lg font-black text-mist">{fact.label}</h2>
            <p class="mt-2 text-sm leading-7 text-muted">{fact.body}</p>
            {fact.note && <p class="mt-2 rounded-md border border-amber/25 bg-violet/20 p-2 text-xs leading-6 text-muted">{fact.note}</p>}
            <p class="mt-3 text-xs leading-6 text-muted">確認日: {fact.checkedAt} / 出典: <a class="text-amber underline-offset-4 hover:underline" href={fact.sourceUrl} target="_blank" rel="noopener noreferrer">{fact.sourceLabel}</a> / {factSourceTypeLabel[fact.sourceType] ?? '要確認'}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <section class="container-navi py-8">
    <SectionTitle title="公式・検索リンク" lead="公演情報、出演者、日程、チケット状況はリンク先で確認してください。" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {venue.officialUrl && <LinkCard title={`${venue.name} 公式ページ`} description="会場公式ページを開きます。設備・アクセス・スケジュールは公式情報を優先してください。" href={venue.officialUrl} cta="公式を見る" />}
      {(venue.ticketSearchLinks ?? []).map((link) => (
        <LinkCard title={link.label} description="チケットサイト側で最新の公演情報を確認してください。当サイトでは公演情報を転載しません。" href={link.url} cta="公式で確認" />
      ))}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle title="関連記事" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {relatedLinks.map((link) => <LinkCard {...link} />)}
    </div>
  </section>
</Layout>
