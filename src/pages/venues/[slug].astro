---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import LinkCard from '@components/LinkCard.astro';
import NoticeBox from '@components/NoticeBox.astro';
import SectionTitle from '@components/SectionTitle.astro';
import venues from '@data/venues.json';
import type { Venue } from '@/types';

export function getStaticPaths() {
  return (venues as Venue[]).map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

interface Props {
  venue: Venue;
}

const { venue } = Astro.props;

const scaleLabel = {
  small: '小箱',
  'small-mid': '小〜中箱',
  mid: '中箱',
  large: '大箱',
  unknown: '規模調査待ち',
}[venue.venueScale];

const typeLabel = {
  small_livehouse: '小箱ライブハウス',
  mid_livehouse: '中箱ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '調査待ち',
}[venue.venueType ?? 'unknown'];

const confidenceLabel = {
  verified: '確認済み',
  partially_verified: '一部確認済み',
  social_only: 'SNS言及ベース',
  verified_or_historical: '履歴情報として確認',
  unknown: '調査待ち',
}[venue.sourceConfidence ?? 'unknown'];

const lockerStatusLabel = {
  available: 'あり',
  none: 'なし',
  limited: '少数',
  unknown: '調査待ち',
}[venue.lockerInfo?.venueLockerStatus ?? 'unknown'];

const cloakStatusLabel = {
  available: 'あり',
  none: 'なし',
  event_dependent: '公演による',
  unknown: '調査待ち',
}[venue.cloakInfo?.cloakStatus ?? 'unknown'];

const availabilityLabel = {
  available: '可',
  unavailable: '不可',
  unknown: '調査待ち',
};

const yesNoUnknownLabel = {
  yes: 'はい',
  no: 'いいえ',
  depends: '状況次第',
  unknown: '調査待ち',
};

const logisticsConfidenceLabel = {
  official: '公式確認',
  mixed: '公式・外部情報混在',
  blog_report: '参戦レポ/会場DB由来',
  sns_report: 'SNS由来',
  unknown: '調査待ち',
};

const blogResearchStatusLabel = {
  researched: '調査済み',
  partial: '一部調査',
  not_found: '見つからず',
  not_started: '未調査',
};

const blogConfidenceLabel: Record<string, string> = {
  high: '高め',
  medium: '中くらい',
  low: '低め',
  unknown: '調査待ち',
};

const signalTopicLabel: Record<string, string> = {
  locker: 'ロッカー',
  cloak: 'クローク',
  baggage: '荷物',
  waiting: '待機',
  access: '行き方',
  restroom: 'トイレ',
  aftershow: '終演後',
  rain: '雨の日',
  convenience: '周辺',
};

const sourceGroupLabel = {
  official: '公式情報',
  personal: '個人ブログ・note・会場DB',
  social: 'SNS・Q&A',
  unknown: 'その他・調査待ち',
};

const sourceGroup = (type: string) => {
  if (type === 'official') return 'official';
  if (['personal_blog', 'blog', 'note', 'venue_database', 'review_site', 'mixed'].includes(type)) return 'personal';
  if (['sns', 'social', 'q_and_a'].includes(type)) return 'social';
  return 'unknown';
};

const accessText = venue.station
  ? `${venue.station}${typeof venue.walkMinutes === 'number' ? `から徒歩目安 ${venue.walkMinutes}分` : 'からの徒歩目安は調査待ち'}`
  : '最寄り駅は調査待ち';

const displayText = (value: unknown) =>
  String(value ?? '')
    .replaceAll('未確認', '調査待ち')
    .replaceAll('要確認', '調査待ち');

const sourceNotes = Array.isArray(venue.sourceNotes) ? venue.sourceNotes : [];
const sourceLinks = venue.sourceLinks ?? [];
const blogSignals = venue.blogSignals ?? [];
const summaryPoints = venue.practicalSummary?.points ?? [];
const title = `${venue.name}のロッカー・クローク・荷物ガイド｜V系ライブ遠征ナビ`;
const description = `${venue.name}へ行く前に確認したい、会場内ロッカー、クローク、駅ロッカー、キャリーケース、物販後の荷物、開場前の待機場所、終演後の動き方をまとめています。`;

const lockerRows = [
  ['会場内ロッカー', lockerStatusLabel],
  ['説明', venue.lockerInfo?.venueLockerText],
  ['個数感', venue.lockerInfo?.lockerCountText],
  ['開場前利用', availabilityLabel[venue.lockerInfo?.beforeEntryUse ?? 'unknown']],
  ['開場後利用', availabilityLabel[venue.lockerInfo?.afterEntryUse ?? 'unknown']],
  ['小銭/100円玉', yesNoUnknownLabel[venue.lockerInfo?.coinNeeded ?? 'unknown']],
  ['大型荷物', yesNoUnknownLabel[venue.lockerInfo?.largeBagFit ?? 'unknown']],
  ['駅ロッカー推奨', yesNoUnknownLabel[venue.lockerInfo?.stationLockerRecommended ?? 'unknown']],
  ['ベストな動き', venue.lockerInfo?.bestMove],
  ['情報確度', logisticsConfidenceLabel[venue.lockerInfo?.sourceConfidence ?? 'unknown']],
  ['確認日', venue.lockerInfo?.lastCheckedAt],
].filter(([, text]) => Boolean(text));

const cloakRows = [
  ['クローク', cloakStatusLabel],
  ['説明', venue.cloakInfo?.cloakText],
  ['料金', venue.cloakInfo?.priceText],
  ['受付タイミング', venue.cloakInfo?.timingText],
  ['預け方', venue.cloakInfo?.bagTypeText],
  ['ベストな動き', venue.cloakInfo?.bestMove],
  ['情報確度', logisticsConfidenceLabel[venue.cloakInfo?.sourceConfidence ?? 'unknown']],
  ['確認日', venue.cloakInfo?.lastCheckedAt],
].filter(([, text]) => Boolean(text));

const baggageRows = [
  ['小さめバッグ', venue.baggageGuide?.smallBag || venue.baggageDecision?.tinyBag],
  ['リュック', venue.baggageGuide?.backpack || venue.baggageDecision?.backpack],
  ['キャリーケース', venue.baggageGuide?.suitcase || venue.baggageDecision?.suitcase],
  ['物販後', venue.baggageGuide?.afterMerch || venue.baggageDecision?.afterMerch],
  ['良番の日', venue.baggageGuide?.goodTicketNumber || venue.baggageDecision?.goodTicketNumber],
].filter(([, text]) => Boolean(text));

const todayMoveRows = [
  ['荷物少なめ', venue.baggageGuide?.smallBag || '小さめバッグならそのまま入場でも対応しやすい。貴重品は体の前で管理する。'],
  ['リュックあり', venue.baggageGuide?.backpack || 'フロアが詰まる日は邪魔になりやすい。駅ロッカーかクロークを先に考える。'],
  ['キャリーあり', venue.baggageGuide?.suitcase || '会場持ち込みは非推奨。駅ロッカー・ホテル・大型荷物預かりを優先する。'],
  ['物販後', venue.baggageGuide?.afterMerch || '物販後に袋が増える前提で、折りたたみサブバッグか預け先を用意する。'],
  ['良番の日', venue.baggageGuide?.goodTicketNumber || '荷物処理を先に終わらせる。入場直前に迷うと番号の良さが消える。'],
];

const nearbyRows = [
  ['近くのコンビニ', venue.nearbyInfo?.nearestConvenienceStore],
  ['駅ロッカー', venue.nearbyInfo?.stationLocker],
  ['待機しやすい場所', venue.nearbyInfo?.waitingSpot],
  ['雨の日の逃げ場', venue.nearbyInfo?.rainShelter],
  ['入場前トイレ', venue.nearbyInfo?.restroomBeforeEntry],
  ['現金・小銭', venue.nearbyInfo?.cashAndCoin],
  ['終演後の帰り方', venue.nearbyInfo?.afterShowRoute],
  ['夜道・繁華街', venue.nearbyInfo?.nightSafety],
].filter(([, text]) => Boolean(text));

const dayDecisionRows = [
  ['荷物ありの日', venue.dayDecisionGuide?.baggageDay],
  ['良番の日', venue.dayDecisionGuide?.goodNumberDay],
  ['物販ありの日', venue.dayDecisionGuide?.merchDay],
  ['雨の日', venue.dayDecisionGuide?.rainyDay],
  ['ぼっち参戦', venue.dayDecisionGuide?.soloDay],
  ['終演後に急ぐ日', venue.dayDecisionGuide?.hurryAfterShowDay],
].filter(([, text]) => Boolean(text));

const groupedSources = sourceLinks.reduce((groups, source) => {
  const group = sourceGroup(source.type) as keyof typeof groups;
  groups[group].push(source);
  return groups;
}, { official: [], personal: [], social: [], unknown: [] } as Record<'official' | 'personal' | 'social' | 'unknown', typeof sourceLinks>);
const sourceGroupKeys = Object.keys(groupedSources) as Array<keyof typeof groupedSources>;

const relatedLinks = [
  { title: 'V系ライブハウス参戦前に知っておきたい豆知識', description: '荷物、ロッカー、ドリンク代、整理番号、撮影ルール、終演後の動きを確認できます。', href: '/guides/livehouse-tips', cta: '読む' },
  { title: '小さいライブハウスのV系ライブ初参戦ガイド', description: '小箱での荷物、立ち位置、整理番号、ロッカー、帰り方を確認できます。', href: '/guides/small-venue', cta: '読む' },
  { title: '持ち物チェックリスト', description: 'チケット、身分証、モバイルバッテリー、雨具、物販用バッグを確認できます。', href: '/guides/belongings', cta: '確認する' },
  { title: '遠征費シミュレーター', description: 'チケット代、交通費、ホテル代、物販予算を入れて合計を確認できます。', href: '/tools/budget', cta: '計算する' },
];
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: '会場攻略', href: '/venues' }, { label: venue.name }]} />

  <section class="container-navi py-8">
    <div class="gothic-panel rounded-xl p-5 md:p-8">
      <p class="gothic-label">{venue.area} / {typeLabel}</p>
      <h1 class="font-classical mt-4 text-3xl font-black leading-tight text-mist md:text-5xl">{venue.name}</h1>
      <p class="mt-4 text-base leading-8 text-muted">{accessText}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">{scaleLabel}</span>
        <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">会場存在: {confidenceLabel}</span>
        <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">最終確認: {venue.lastVerifiedAt}</span>
        {venue.minorVkeiFriendly && <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">若手V系向き</span>}
      </div>
      {venue.tipTags?.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {venue.tipTags.map((tag) => <span class="rounded-md border border-amber/20 bg-black/30 px-2.5 py-1 text-xs font-black text-muted">{tag}</span>)}
        </div>
      )}
    </div>
  </section>

  {(venue.sourceConfidence === 'social_only' || venue.sourceConfidence === 'unknown') && (
    <section class="container-navi pb-6">
      <NoticeBox title="調査待ちの会場情報です" tone="warning">
        <p>この会場情報はSNS上の言及や未検証情報をもとに仮登録している可能性があります。会場公式・チケットサイトでの確認が完了するまで、掲載内容は調査待ちとして扱います。</p>
      </NoticeBox>
    </section>
  )}

  <section class="container-navi grid gap-6 pb-12 lg:grid-cols-[1fr_0.38fr] lg:items-start">
    <div class="space-y-8">
      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="30 seconds" title="30秒結論" lead={venue.practicalSummary?.headline || '当日の動き方を短く整理します。'} />
        {summaryPoints.length > 0 ? (
          <ul class="grid gap-3">
            {summaryPoints.map((point) => (
              <li class="rounded-md border border-amber/20 bg-black/25 px-4 py-3 text-sm font-bold leading-7 text-mist">{point}</li>
            ))}
          </ul>
        ) : (
          <p class="text-sm leading-7 text-muted">この会場の30秒結論はまだ編集中です。荷物が多い日は駅ロッカーやホテル預けを先に検討してください。</p>
        )}
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Today" title="今日の動き方" lead="荷物量、物販、整理番号で迷ったときに、まずこの通りに動けるように整理しています。" />
        <div class="today-move-grid">
          {todayMoveRows.map(([label, text]) => (
            <article class="today-move-card">
              <p class="gothic-label">{label}</p>
              <p>{displayText(text)}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Locker" title="ロッカー情報" lead="抽象スコアではなく、会場内ロッカーの有無・使えるタイミング・代替案を表示します。" />
        <dl class="grid gap-3">
          {lockerRows.map(([label, text]) => (
            <div class="rounded-md border border-amber/20 bg-black/25 p-4">
              <dt class="gothic-label">{label}</dt>
              <dd class="mt-2 text-sm font-bold leading-7 text-mist">{displayText(text)}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Cloak" title="クローク情報" lead="常設か、公演ごとの運用か、料金や受付タイミングが分かる範囲で整理します。" />
        <dl class="grid gap-3">
          {cloakRows.map(([label, text]) => (
            <div class="rounded-md border border-amber/20 bg-black/25 p-4">
              <dt class="gothic-label">{label}</dt>
              <dd class="mt-2 text-sm font-bold leading-7 text-mist">{displayText(text)}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Baggage" title="荷物別の動き方" lead="小さめバッグ、リュック、キャリー、物販後、良番の日で動きを分けます。" />
        <dl class="grid gap-3">
          {baggageRows.map(([label, text]) => (
            <div class="rounded-md border border-amber/20 bg-black/25 p-4">
              <dt class="gothic-label">{label}</dt>
              <dd class="mt-2 text-sm leading-7 text-mist">{displayText(text)}</dd>
            </div>
          ))}
        </dl>
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Nearby" title="周辺情報" lead="コンビニ、駅ロッカー、待機場所、雨の日、終演後の帰り方を当日目線で整理します。" />
        <dl class="grid gap-3">
          {nearbyRows.map(([label, text]) => (
            <div class="rounded-md border border-amber/20 bg-black/25 p-4">
              <dt class="gothic-label">{label}</dt>
              <dd class="mt-2 text-sm leading-7 text-mist">{displayText(text)}</dd>
            </div>
          ))}
        </dl>
      </section>

      {dayDecisionRows.length > 0 && (
        <section class="gothic-card rounded-xl p-5 md:p-6">
          <SectionTitle eyebrow="Decision" title="当日判断" lead="良番、物販、雨、ぼっち参戦、終演後に急ぐ日など、公式情報だけでは分かりにくい動きを整理します。" />
          <dl class="grid gap-3">
            {dayDecisionRows.map(([label, text]) => (
              <div class="rounded-md border border-amber/20 bg-black/25 p-4">
                <dt class="gothic-label">{label}</dt>
                <dd class="mt-2 text-sm leading-7 text-mist">{displayText(text)}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Reports" title="参戦レポから見える傾向" lead={venue.blogResearch?.summary || '参戦レポ由来情報はまだ整理中です。'} />
        <div class="rounded-md border border-amber/20 bg-black/25 p-4 text-sm leading-7 text-muted">
          <p>調査状況: <span class="font-black text-mist">{blogResearchStatusLabel[venue.blogResearch?.status ?? 'not_started']}</span></p>
          <p>確度: <span class="font-black text-mist">{blogConfidenceLabel[venue.blogResearch?.confidence ?? 'unknown']}</span></p>
          {venue.blogResearch?.checkedAt && <p>確認日: <span class="font-black text-mist">{venue.blogResearch.checkedAt}</span></p>}
        </div>
        {blogSignals.length > 0 ? (
          <div class="mt-4 grid gap-3">
            {blogSignals.map((signal) => (
              <article class="rounded-md border border-amber/20 bg-black/25 p-4">
                <p class="gothic-label">{signalTopicLabel[signal.topic] ?? '参戦メモ'} / {blogConfidenceLabel[signal.confidence]}</p>
                <p class="mt-2 text-sm leading-7 text-mist">{signal.summary}</p>
                <p class="mt-2 text-xs leading-6 text-muted">{signal.copyrightNote}</p>
              </article>
            ))}
          </div>
        ) : (
          <p class="mt-4 text-sm leading-7 text-muted">参戦レポ由来の傾向はまだ登録されていません。</p>
        )}
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Beginner / Solo" title="ぼっち参戦・初参戦メモ" />
        <div class="grid gap-3 md:grid-cols-2">
          <div class="rounded-md border border-amber/20 bg-black/25 p-4">
            <p class="gothic-label">ぼっち参戦</p>
            <p class="mt-2 text-sm leading-7 text-mist">{venue.soloOneLine || venue.soloStrategy || venue.soloNote || '会場前で無理に交流しなくてOK。整列開始までは駅周辺で時間調整する。'}</p>
          </div>
          <div class="rounded-md border border-amber/20 bg-black/25 p-4">
            <p class="gothic-label">初参戦</p>
            <p class="mt-2 text-sm leading-7 text-mist">{venue.beginnerOneLine || venue.beginnerStrategy || venue.beginnerNote || '入口、整理番号、ドリンク代、荷物の預け先を入場前に決める。'}</p>
          </div>
        </div>
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <SectionTitle eyebrow="Sources" title="情報ソース" lead="公式情報と個人ブログ・note・SNS/Q&A由来情報を分けて表示します。" />
        <NoticeBox title="参戦レポ情報の扱い" tone="warning">
          <p>個人ブログ・note由来の情報は、本文をコピーせず、要点のみ独自表現で整理しています。設備や運用は公演・時期により変わる可能性があります。</p>
        </NoticeBox>
        <div class="mt-5 grid gap-4">
          {sourceGroupKeys.map((key) => (
            <div class="rounded-md border border-amber/20 bg-black/25 p-4">
              <p class="font-classical font-black text-mist">{sourceGroupLabel[key]}</p>
              {groupedSources[key].length > 0 ? (
                <ul class="mt-3 space-y-2 text-sm leading-6 text-muted">
                  {groupedSources[key].map((source) => (
                    <li>
                      {source.url ? (
                        <a class="text-amber underline underline-offset-4" href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a>
                      ) : (
                        <span>{source.label}</span>
                      )}
                      <span> / {source.checkedAt}</span>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="mt-3 text-sm text-muted">調査待ち</p>
              )}
            </div>
          ))}
        </div>
        {sourceNotes.length > 0 && (
          <div class="mt-5 rounded-md border border-amber/20 bg-black/25 p-4">
            <p class="font-classical font-black text-mist">調査待ちメモ</p>
            <ul class="mt-3 space-y-2 text-sm leading-6 text-muted">
              {sourceNotes.map((note) => <li>{displayText(note)}</li>)}
            </ul>
          </div>
        )}
      </section>
    </div>

    <aside class="space-y-5 lg:sticky lg:top-24">
      <div class="gothic-card rounded-xl p-5">
        <p class="font-classical text-lg font-black text-mist">公式・検索リンク</p>
        <div class="mt-4 grid gap-3">
          {venue.officialUrl ? (
            <a class="gothic-button focus-ring inline-flex min-h-11 items-center justify-center rounded-md px-4 text-sm font-black" href={venue.officialUrl} target="_blank" rel="noopener noreferrer">会場公式を見る</a>
          ) : (
            <p class="rounded-md border border-amber/20 bg-black/25 p-3 text-sm leading-6 text-muted">公式URLは調査待ちです。会場名で検索して最新情報を確認してください。</p>
          )}
          {(venue.ticketSearchLinks ?? []).map((link) => (
            <a class="gothic-button-secondary focus-ring inline-flex min-h-11 items-center justify-center rounded-md px-4 text-sm font-black" href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </div>
      </div>

      <NoticeBox title="公演情報は公式で確認" tone="warning">
        <p>このページでは公演名、出演者、日程、チケット状況を掲載しません。最新の公演情報は必ず公式サイト、チケットサイト、会場公式スケジュールで確認してください。</p>
      </NoticeBox>
    </aside>
  </section>

  <section class="container-navi pb-12">
    <SectionTitle eyebrow="Related" title="関連記事" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {relatedLinks.map((link) => <LinkCard {...link} />)}
    </div>
  </section>
</Layout>
