---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import MonetizationBox from '@components/MonetizationBox.astro';
import RelatedGuideLinks from '@components/RelatedGuideLinks.astro';
import venues from '@data/venues.json';
import type { SourceLink, Venue } from '@/types';

export function getStaticPaths() {
  return (venues as Venue[]).map((venue) => ({
    params: { slug: venue.slug },
    props: { venue },
  }));
}

interface Props {
  venue: Venue;
}

const { venue } = Astro.props;

const typeLabels: Record<string, string> = {
  small_livehouse: '小規模ライブハウス',
  mid_livehouse: '中規模ライブハウス',
  large_livehouse: '大型ライブハウス',
  hall: 'ホール',
  theater: '劇場',
  outdoor_stage: '屋外ステージ',
  event_space: 'イベントスペース',
  closed_archive: '閉館アーカイブ',
  unknown: '種別確認中',
};

const lockerStatusLabels: Record<string, string> = {
  available: 'あり',
  limited: '少数',
  none: 'なし',
  unknown: '確認中',
};

const cloakStatusLabels: Record<string, string> = {
  available: 'あり',
  event_dependent: '公演による',
  none: 'なし',
  unknown: '確認中',
};

const confidenceLabels: Record<string, string> = {
  official: '公式確認',
  supporting_reference: '補助確認',
  mixed: '補助確認',
  venue_database: '補助確認',
  review_site: '補助確認',
  blog_report: '補助確認',
  sns_report: '補助確認',
  unknown: '確認中',
};

const sourceTypeLabels: Record<string, string> = {
  official: '公式確認',
  supporting_reference: '補助確認',
  venue_database: '会場情報DB',
  ticket_site: 'チケット会社',
  ticket_site_or_user_list: 'チケット会社',
  unknown: '確認中',
};

const allowedPublicSourceTypes = new Set(['official', 'supporting_reference', 'venue_database', 'ticket_site', 'ticket_site_or_user_list']);
const privateSourceTypes = new Set(['personal_blog', 'blog', 'note', 'sns', 'q_and_a', 'mixed']);
const privateSourceUrlPatterns = [
  'note.com',
  'ameblo.jp',
  'hatenablog.',
  'seesaa.net',
  'twitter.com',
  'x.com/',
  'twstalker.com',
  'instagram.com',
  'tiktok.com',
];

const normalizeSourceUrl = (url: unknown) => {
  const value = String(url ?? '').trim();
  if (!value) return '';
  try {
    const normalized = new URL(value);
    normalized.searchParams.delete('utm_source');
    normalized.searchParams.delete('utm_medium');
    normalized.searchParams.delete('utm_campaign');
    return `${normalized.origin}${normalized.pathname}${normalized.search || ''}`;
  } catch {
    return value;
  }
};

const dedupeSourceLinks = (links: SourceLink[]) => {
  const exact = new Map<string, SourceLink>();

  for (const link of links) {
    const source = {
      ...link,
      label: String(link.label ?? '').trim(),
      url: normalizeSourceUrl(link.url),
      type: link.type ?? 'unknown',
    };
    if (!source.label && !source.url) continue;

    const key = [source.url, source.label, source.type].join('|');
    const existing = exact.get(key);
    exact.set(key, {
      ...existing,
      ...source,
      checkedAt: source.checkedAt || existing?.checkedAt,
    } as SourceLink);
  }

  const byNameAndType = new Map<string, SourceLink>();
  for (const source of exact.values()) {
    const key = [source.label, source.type].join('|');
    const existing = byNameAndType.get(key);
    if (!existing || (!existing.url && source.url)) {
      byNameAndType.set(key, source);
    }
  }

  return [...byNameAndType.values()];
};

const cleanText = (value: unknown) =>
  String(value ?? '')
    .replace(/\bunknown\b/g, '確認中')
    .replaceAll('未確認', '確認中')
    .replaceAll('未調査', '確認中')
    .replaceAll('ヴィジュアル系', '推し活')
    .replaceAll('ビジュアル系', '推し活')
    .replaceAll('V系', '推し活')
    .replaceAll('小箱ライブ', '小規模会場')
    .replaceAll('小箱', '小規模')
    .trim();

const genericPublicPhrases = [
  '荷物が多い日は駅ロッカーかホテル預けを先に決める',
  '荷物が多い日は、駅到着時点でロッカーや預け先を決めてから会場へ向かう',
  '駅周辺で時間調整する',
  '周辺情報は確認中です',
  '大荷物は駅側で荷物処理',
  '公式アクセス参照',
  '地図アプリで直前確認',
  '荷物が多い日は最寄り駅や主要駅ロッカーも候補',
  '整列開始までは会場前に長くたまらず、駅周辺で時間調整する',
  '雨の日は駅周辺や商業施設など屋根のある場所で整える',
  '入場前に駅や周辺施設で済ませる',
  '終演後は駅までの導線と荷物回収時間を先に決める',
  '初めての会場は帰りの駅ルートを事前保存する',
  '周辺コンビニは事前に地図アプリで確認推奨',
  '開場前の待機は近隣迷惑にならないよう',
  '夜の帰り道は駅までのルートを事前確認推奨',
  '終演後はまず荷物回収と駅までのルート',
  '背中のリュックはフロアで邪魔になりやすい',
  '最寄り駅周辺ロッカーは埋まることがある',
];

const isGenericPublicText = (value: unknown) => {
  const text = cleanText(value);
  return genericPublicPhrases.some((phrase) => text.includes(phrase));
};

const isUnknownValue = (value: unknown) => {
  if (!value) return true;
  const text = cleanText(value);
  return text === '確認中' || text === 'なし該当なし';
};

const isUsefulText = (value: unknown) => {
  if (!value) return false;
  const text = cleanText(value);
  return Boolean(text) && text !== '確認中' && text !== 'なし該当なし' && !isGenericPublicText(text);
};

const toUsefulList = (value: unknown) => {
  const values = Array.isArray(value) ? value : [value];
  return values.map(cleanText).filter((item) => isUsefulText(item));
};

const firstUsefulList = (...values: unknown[]) => {
  for (const value of values) {
    const list = toUsefulList(value);
    if (list.length > 0) return list;
  }
  return [];
};

const placeValues = (type: string) =>
  (venue.nearbyInfo?.places ?? [])
    .filter((place) => place.type === type)
    .map((place) => {
      const notes = [
        place.directionNote,
        typeof place.walkMinutes === 'number' ? `徒歩目安${place.walkMinutes}分` : '',
        typeof place.distanceMeters === 'number' ? `約${place.distanceMeters}m` : '',
      ].filter(Boolean);
      return notes.length > 0 ? `${place.name}（${notes.join('・')}）` : place.name;
    })
    .filter(isUsefulText);

const isPublicSource = (source: SourceLink) => {
  const type = source.type ?? 'unknown';
  const url = normalizeSourceUrl(source.url).toLowerCase();
  if (privateSourceTypes.has(type)) return false;
  if (privateSourceUrlPatterns.some((pattern) => url.includes(pattern))) return false;
  return allowedPublicSourceTypes.has(type);
};

const normalizeStationLocker = (value: unknown) => {
  if (value === true) return 'yes';
  if (value === false) return 'no';
  return String(value || 'unknown');
};

const normalizeToken = (value: unknown) => {
  if (value === true) return 'true';
  if (value === false) return 'false';
  if (value === null || value === undefined || value === '') return '';
  return String(value);
};

const formatUseTiming = (value: unknown, phase: 'before' | 'after') => {
  const token = normalizeToken(value);
  if (!token) return '';
  const label = phase === 'before' ? '開場前' : '開場後';
  const useLabel = phase === 'before' ? '開場前に使える' : '開場後に使える';
  const notFoundLabel = phase === 'before' ? '開場前利用は確認できず' : '開場後利用は確認できず';
  const labels: Record<string, string> = {
    true: useLabel,
    available: useLabel,
    false: notFoundLabel,
    unavailable: notFoundLabel,
    no: notFoundLabel,
    unknown: '確認中',
    event_dependent: '公演により変動',
    organizer_dependent: '主催者判断',
  };
  return labels[token] ?? `${label}の運用は確認中`;
};

const formatCoinRequirement = (value: unknown) => {
  const token = normalizeToken(value);
  if (!token) return '';
  const labels: Record<string, string> = {
    true: '100円玉を用意',
    yes: '100円玉を用意',
    required: '100円玉を用意',
    false: '100円玉指定なし',
    no: '100円玉指定なし',
    not_required: '100円玉指定なし',
    unknown: '確認中',
  };
  return labels[token] ?? '確認中';
};

const formatLargeBaggage = (value: unknown) => {
  const token = normalizeToken(value);
  if (!token) return '';
  const labels: Record<string, string> = {
    true: '大型荷物も対応可',
    yes: '大型荷物も対応可',
    accepted: '大型荷物も対応可',
    limited: 'サイズ次第',
    false: '大型荷物は避ける',
    no: '大型荷物は避ける',
    not_recommended: '大型荷物は避ける',
    station_recommended: '駅ロッカー・ホテル預け推奨',
    unknown: '要確認',
  };
  return labels[token] ?? '要確認';
};

const formatStationLockerRecommendation = (value: unknown) => {
  const token = normalizeToken(value);
  if (!token) return '';
  const labels: Record<string, string> = {
    true: '駅ロッカー先行がおすすめ',
    yes: '駅ロッカー先行がおすすめ',
    false: '会場設備で足りる可能性あり',
    no: '会場設備で足りる可能性あり',
    depends: '荷物量・整理番号次第',
    situation_dependent: '荷物量・整理番号次第',
    conditional: '荷物量・整理番号次第',
    unknown: '状況次第',
  };
  return labels[token] ?? '状況次第';
};

const locker = venue.lockerInfo;
const cloak = venue.cloakInfo;
const effectiveVenueStatus = venue.venueStatus ?? venue.status;
const isArchive = venue.archiveOnly || effectiveVenueStatus === 'closed';
const stationLockerRecommended = normalizeStationLocker(locker?.stationLockerRecommended ?? 'unknown');
const coinRequirementText = locker && isUsefulText(locker.coinText)
  ? cleanText(locker.coinText)
  : locker?.coinNeeded && locker.coinNeeded !== 'unknown'
    ? formatCoinRequirement(locker.coinNeeded)
    : '';
const largeBaggageText = locker && isUsefulText(locker.largeBagText)
  ? cleanText(locker.largeBagText)
  : locker?.largeBagFit && locker.largeBagFit !== 'unknown'
    ? formatLargeBaggage(locker.largeBagFit)
    : '';
const stationLockerText = stationLockerRecommended !== 'unknown' ? formatStationLockerRecommendation(stationLockerRecommended) : '';
const venueSourceConfidence = venue.sourceConfidence ?? 'unknown';
const archiveSummary = '閉館アーカイブのため、現在利用前提のロッカー・クローク案内は表示していません。';
const rawSummaryHeadline = isArchive ? archiveSummary : venue.practicalSummary?.headline || '';
const summaryHeadline = isArchive || isUsefulText(rawSummaryHeadline) ? cleanText(rawSummaryHeadline) : '';
const summaryPoints = isArchive ? [] : (venue.practicalSummary?.points ?? []).map(cleanText).filter(isUsefulText);
const sourceLinks = dedupeSourceLinks(((venue.publicSources ?? venue.sourceLinks) ?? []).filter(isPublicSource));

const title = isArchive
  ? `${venue.name}の閉館アーカイブ｜推し活遠征ナビ`
  : `${venue.name}の行き方・ロッカー・コンビニ・終演後の帰り方｜推し活遠征ナビ`;
const description = isArchive
  ? `${venue.name}は閉館アーカイブとして掲載しています。現在利用前提の設備案内ではなく、過去会場情報として整理しています。`
  : `${venue.name}へ行く前に確認したい、最寄出口、駅ロッカー、クローク、近くのコンビニ、開場前の待機場所、トイレ、雨の日、終演後の帰り方、夜道の注意点をまとめています。`;
const accessText = venue.station
  ? `${venue.station}${typeof venue.walkMinutes === 'number' ? `から徒歩目安 ${venue.walkMinutes}分` : ''}`
  : '最寄り駅は確認中';

const baggageRows = isArchive ? [] : [
  ['小さい荷物の日', venue.baggageGuide?.smallBag || venue.baggageDecision?.tinyBag],
  ['リュックの日', venue.baggageGuide?.backpack || venue.baggageDecision?.backpack],
  ['キャリーありの日', venue.baggageGuide?.suitcase || venue.baggageDecision?.suitcase],
  ['物販後に荷物が増える日', venue.baggageGuide?.afterMerch || venue.baggageDecision?.afterMerch],
  ['良番の日', venue.baggageGuide?.goodTicketNumber || venue.baggageDecision?.goodTicketNumber],
  ['雨の日', venue.dayDecisionGuide?.rainyDay || venue.nearbyInfo?.rainPlan || venue.nearbyInfo?.rainShelter],
  ['終演後に急ぐ日', venue.dayDecisionGuide?.hurryAfterShowDay || venue.nearbyInfo?.afterShowRoute],
].filter(([, text]) => isUsefulText(text));

const dayFlowRows = isArchive ? [] : [
  ['駅到着', venue.nearbyInfo?.dayFlow?.stationArrival || venue.nearbyInfo?.arrivalRoute],
  ['荷物を減らす', venue.nearbyInfo?.dayFlow?.baggageDrop || venue.nearbyInfo?.baggageFlow],
  ['開場前', venue.nearbyInfo?.dayFlow?.beforeEntry || venue.nearbyInfo?.waitingRule || venue.nearbyInfo?.waitingSpot],
  ['入場直前', venue.nearbyInfo?.dayFlow?.entry || firstUsefulList(venue.nearbyInfo?.restrooms, venue.nearbyInfo?.restroomBeforeEntry)[0]],
  ['公演中', venue.nearbyInfo?.dayFlow?.duringShow],
  ['終演後', venue.nearbyInfo?.dayFlow?.afterShow || venue.nearbyInfo?.afterShowRoute],
  ['終電・夜行前', venue.nearbyInfo?.dayFlow?.lastTrainNote || venue.nearbyInfo?.tripNote],
].filter(([, text]) => isUsefulText(text));

const lockerRows = isArchive ? [] : [
  locker && locker.venueLockerStatus !== 'unknown' ? ['会場内ロッカー', lockerStatusLabels[locker.venueLockerStatus ?? 'unknown']] : null,
  locker && isUsefulText(locker.lockerCountText) ? ['ロッカー個数', cleanText(locker.lockerCountText)] : null,
  locker && isUsefulText(locker.priceText) ? ['ロッカー料金', cleanText(locker.priceText)] : null,
  locker && isUsefulText(locker.timingText) ? ['利用タイミング', cleanText(locker.timingText)] : null,
  locker && locker.beforeEntryUse && locker.beforeEntryUse !== 'unknown' ? ['開場前利用', formatUseTiming(locker.beforeEntryUse, 'before')] : null,
  locker && locker.afterEntryUse && locker.afterEntryUse !== 'unknown' ? ['開場後利用', formatUseTiming(locker.afterEntryUse, 'after')] : null,
  locker && coinRequirementText ? ['小銭・100円玉', coinRequirementText] : null,
  locker && largeBaggageText ? ['大型荷物', largeBaggageText] : null,
  locker && stationLockerText ? ['駅ロッカー', stationLockerText] : null,
  locker && isUsefulText(locker.bestMove) ? ['最善の動き方', cleanText(locker.bestMove)] : null,
  locker ? ['出典区分', confidenceLabels[locker.sourceConfidence ?? venueSourceConfidence]] : null,
  locker?.lastCheckedAt || locker?.checkedAt ? ['確認日', locker.lastCheckedAt || locker.checkedAt] : null,
].filter(Boolean) as Array<[string, string]>;

const cloakRows = isArchive ? [] : [
  cloak && cloak.cloakStatus !== 'unknown' ? ['クローク', cloakStatusLabels[cloak.cloakStatus ?? 'unknown']] : null,
  cloak && isUsefulText(cloak.priceText) ? ['料金', cleanText(cloak.priceText)] : null,
  cloak && isUsefulText(cloak.timingText) ? ['受付タイミング', cleanText(cloak.timingText)] : null,
  cloak && isUsefulText(cloak.bagTypeText) ? ['預け方', cleanText(cloak.bagTypeText)] : null,
  cloak && isUsefulText(cloak.bestMove) ? ['最善の動き方', cleanText(cloak.bestMove)] : null,
  cloak ? ['出典区分', confidenceLabels[cloak.sourceConfidence ?? venueSourceConfidence]] : null,
  cloak?.lastCheckedAt || cloak?.checkedAt ? ['確認日', cloak.lastCheckedAt || cloak.checkedAt] : null,
].filter(Boolean) as Array<[string, string]>;

const nearbyRows = isArchive ? [] : [
  { label: '最寄出口', values: firstUsefulList(venue.nearbyInfo?.nearestExit) },
  { label: '近いコンビニ', values: firstUsefulList(placeValues('convenience_store'), venue.nearbyInfo?.convenienceStores, venue.nearbyInfo?.nearestConvenienceStore, venue.nearbyInfo?.convenienceStore) },
  { label: '駅ロッカー候補', values: firstUsefulList(placeValues('station_locker'), venue.nearbyInfo?.stationLockers, venue.nearbyInfo?.stationLocker) },
  { label: '開場前の待機場所', values: firstUsefulList(venue.nearbyInfo?.waitingRule, venue.nearbyInfo?.waitingSpot) },
  { label: 'トイレ候補', values: firstUsefulList(placeValues('restroom'), venue.nearbyInfo?.restrooms, venue.nearbyInfo?.restroomBeforeEntry) },
  { label: '雨の日', values: firstUsefulList(venue.nearbyInfo?.rainPlan, venue.nearbyInfo?.rainShelter) },
  { label: '終演後の帰り方', values: firstUsefulList(venue.nearbyInfo?.afterShowRoute) },
  { label: '夜道・女性ソロ注意', values: firstUsefulList(venue.nearbyInfo?.nightSafety) },
].filter((row) => row.values.length > 0);

const beginnerRows = isArchive ? [] : [
  ['初参戦メモ', venue.nearbyInfo?.soloBeginnerNote || venue.beginnerOneLine],
  ['一人参戦', venue.nearbyInfo?.nightSafety || venue.soloOneLine || venue.soloStrategy],
].filter(([, text]) => isUsefulText(text));

const tripRows = isArchive ? [] : [
  ['遠征者メモ', venue.nearbyInfo?.tripNote],
  ['キャリーケース', venue.baggageGuide?.suitcase || venue.carryCaseWarning],
  ['物販で荷物が増える日', venue.baggageGuide?.afterMerch || venue.nearbyInfo?.baggageFlow],
  ['終電・夜行バス前', venue.nearbyInfo?.dayFlow?.lastTrainNote || venue.afterShowStrategy],
  ['雨の日の荷物', venue.nearbyInfo?.rainPlan || venue.badWeatherNote],
].filter(([, text]) => isUsefulText(text));

const unknownRows = isArchive ? [] : [
  locker?.venueLockerStatus === 'unknown' ? '会場内ロッカー' : '',
  isUnknownValue(locker?.lockerCountText) ? 'ロッカー個数' : '',
  locker?.beforeEntryUse === 'unknown' ? '開場前ロッカー利用' : '',
  locker?.afterEntryUse === 'unknown' ? '開場後ロッカー利用' : '',
  locker?.coinNeeded === 'unknown' ? '小銭・100円玉' : '',
  locker?.largeBagFit === 'unknown' ? '大型荷物対応' : '',
  cloak?.cloakStatus === 'unknown' ? 'クローク有無' : '',
  isUnknownValue(cloak?.timingText) ? 'クローク受付タイミング' : '',
  isUnknownValue(cloak?.bagTypeText) ? 'クローク預け方' : '',
  stationLockerRecommended === 'unknown' ? '駅ロッカー判断' : '',
].filter(Boolean);

---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: '会場攻略', href: '/venues' }, { label: venue.name }]} />

  <section class="container-navi py-8">
    <div class="gothic-panel rounded-xl p-5 md:p-8">
      <p class="gothic-label">{venue.area} / {typeLabels[venue.venueType ?? 'unknown']}</p>
      <h1 class="font-classical mt-4 text-3xl font-black leading-tight text-mist md:text-5xl">{venue.name}</h1>
      <p class="mt-4 text-base leading-8 text-muted">{accessText}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {venue.minorVkeiFriendly && <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">小規模現場向き</span>}
        {venue.tipTags?.slice(0, 5).map((tag) => <span class="gothic-chip rounded-md px-3 py-1 text-xs font-black">{cleanText(tag)}</span>)}
      </div>
    </div>
  </section>

  <section class="container-navi grid gap-6 pb-12 lg:grid-cols-[1fr_0.36fr] lg:items-start">
    <div class="space-y-8">
      <section class="gothic-card rounded-xl p-5 md:p-6">
        <div class="section-title">
          <p>30 seconds</p>
          <h2>30秒結論</h2>
          <p>{summaryHeadline || 'この会場の30秒結論は確認中です。'}</p>
        </div>
        {summaryPoints.length > 0 && (
          <ul class="grid gap-3">
            {summaryPoints.map((point) => (
              <li class="rounded-md border border-amber/20 bg-black/25 px-4 py-3 text-sm font-bold leading-7 text-mist">{point}</li>
            ))}
          </ul>
        )}
      </section>

      {!isArchive && (
        <>
      <section class="gothic-card rounded-xl p-5 md:p-6">
        <div class="section-title">
          <p>Flow</p>
          <h2>当日の流れ</h2>
          <p>駅に着いてから終演後に戻るまで、初めてでも迷いにくい順番で確認します。</p>
        </div>
        {dayFlowRows.length > 0 ? (
          <ol class="grid gap-3">
            {dayFlowRows.map(([label, text], index) => (
              <li class="grid gap-3 rounded-md border border-amber/20 bg-black/25 p-4 sm:grid-cols-[auto_1fr]">
                <span class="gothic-chip inline-flex size-9 items-center justify-center rounded-md text-sm font-black">{index + 1}</span>
                <div>
                  <p class="font-classical text-base font-black text-mist">{label}</p>
                  <p class="mt-1 text-sm leading-7 text-muted">{cleanText(text)}</p>
                </div>
              </li>
            ))}
          </ol>
        ) : (
          <p class="rounded-md border border-amber/20 bg-black/25 p-4 text-sm leading-7 text-muted">当日の流れは確認中です。</p>
        )}
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <div class="section-title">
          <p>Nearby</p>
          <h2>会場周辺クイック情報</h2>
          <p>最寄出口、コンビニ、待機場所、雨の日、終演後の戻り方を当日目線で確認します。</p>
        </div>
        {nearbyRows.length > 0 ? (
          <dl class="grid gap-3 md:grid-cols-2">
            {nearbyRows.map((row) => (
              <div class="rounded-md border border-amber/20 bg-black/25 p-4">
                <dt class="gothic-label">{row.label}</dt>
                <dd class="mt-2 text-sm leading-7 text-mist">
                  {row.values.length > 1 ? (
                    <ul class="list-disc space-y-1 pl-5">
                      {row.values.map((value) => <li>{value}</li>)}
                    </ul>
                  ) : (
                    row.values[0]
                  )}
                </dd>
              </div>
            ))}
          </dl>
        ) : (
          <p class="rounded-md border border-amber/20 bg-black/25 p-4 text-sm leading-7 text-muted">会場周辺クイック情報は確認中です。</p>
        )}
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <div class="section-title">
          <p>Today</p>
          <h2>今日の動き方</h2>
          <p>荷物量、物販予定、整理番号、雨、終演後の予定で先に動きを決めておきます。</p>
        </div>
        {baggageRows.length > 0 ? (
          <div class="today-move-grid">
            {baggageRows.map(([label, text]) => (
              <article class="today-move-card">
                <p class="gothic-label">{label}</p>
                <p>{cleanText(text)}</p>
              </article>
            ))}
          </div>
        ) : (
          <p class="rounded-md border border-amber/20 bg-black/25 p-4 text-sm leading-7 text-muted">今日の動き方は確認中です。</p>
        )}
      </section>

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <div class="section-title">
          <p>Baggage</p>
          <h2>荷物をどうするか</h2>
          <p>ロッカー／クロークは荷物判断の一要素として扱います。初めて行く日は、駅ロッカーやクロークの方針を先に決めておくと動きやすくなります。</p>
        </div>
        {(lockerRows.length > 0 || cloakRows.length > 0) ? (
          <div class="grid gap-5 lg:grid-cols-2">
            {lockerRows.length > 0 && (
              <div>
                <h3 class="font-classical text-xl font-black text-mist">ロッカー情報</h3>
                <dl class="mt-4 grid gap-3">
                  {lockerRows.map(([label, text]) => (
                    <div class="rounded-md border border-amber/20 bg-black/25 p-4">
                      <dt class="gothic-label">{label}</dt>
                      <dd class="mt-2 text-sm font-bold leading-7 text-mist">{cleanText(text)}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
            {cloakRows.length > 0 && (
              <div>
                <h3 class="font-classical text-xl font-black text-mist">クローク情報</h3>
                <dl class="mt-4 grid gap-3">
                  {cloakRows.map(([label, text]) => (
                    <div class="rounded-md border border-amber/20 bg-black/25 p-4">
                      <dt class="gothic-label">{label}</dt>
                      <dd class="mt-2 text-sm font-bold leading-7 text-mist">{cleanText(text)}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
          </div>
        ) : (
          <p class="rounded-md border border-amber/20 bg-black/25 p-4 text-sm leading-7 text-muted">ロッカー・クロークの具体情報は確認中です。</p>
        )}
      </section>

      <MonetizationBox
        title="この会場へ行く前に用意すると安心なもの"
        lead="雨の日、物販後、終演後移動で困りにくい持ち物を中心にまとめています。"
      />

      {(beginnerRows.length > 0 || tripRows.length > 0) && (
        <section class="gothic-card rounded-xl p-5 md:p-6">
          <div class="section-title">
            <p>Memo</p>
            <h2>初参戦・遠征者メモ</h2>
            <p>初めて行く人や、キャリー・宿泊・終電が絡む人向けの注意点です。</p>
          </div>
          <div class="grid gap-4 lg:grid-cols-2">
            {beginnerRows.length > 0 && (
              <div>
                <h3 class="font-classical text-xl font-black text-mist">初参戦メモ</h3>
                <dl class="mt-4 grid gap-3">
                  {beginnerRows.map(([label, text]) => (
                    <div class="rounded-md border border-amber/20 bg-black/25 p-4">
                      <dt class="gothic-label">{label}</dt>
                      <dd class="mt-2 text-sm leading-7 text-mist">{cleanText(text)}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
            {tripRows.length > 0 && (
              <div>
                <h3 class="font-classical text-xl font-black text-mist">遠征者メモ</h3>
                <dl class="mt-4 grid gap-3">
                  {tripRows.map(([label, text]) => (
                    <div class="rounded-md border border-amber/20 bg-black/25 p-4">
                      <dt class="gothic-label">{label}</dt>
                      <dd class="mt-2 text-sm leading-7 text-mist">{cleanText(text)}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
          </div>
        </section>
      )}

        </>
      )}

      <section class="gothic-card rounded-xl p-5 md:p-6">
        <div class="section-title">
          <h2>出典</h2>
          <p>公開ページでは、公式確認と補助確認だけを表示します。</p>
        </div>
        {sourceLinks.length > 0 ? (
          <ul class="space-y-3 text-sm leading-6 text-muted">
            {sourceLinks.map((source) => (
              <li class="rounded-md border border-amber/10 bg-black/20 p-3">
                {source.url ? (
                  <a class="text-amber underline underline-offset-4" href={source.url} target="_blank" rel="noopener noreferrer">{source.label}</a>
                ) : (
                  <span class="text-mist">{source.label}</span>
                )}
                <span class="mx-2 text-muted">｜</span>
                <span>{sourceTypeLabels[source.type] ?? '確認中'}</span>
                {source.checkedAt && (
                  <>
                    <span class="mx-2 text-muted">｜</span>
                    <span>確認日：{source.checkedAt}</span>
                  </>
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p class="rounded-md border border-amber/20 bg-black/25 p-4 text-sm leading-7 text-muted">公式確認・補助確認の表示情報は確認中です。</p>
        )}
      </section>

      {!isArchive && unknownRows.length > 0 && (
        <section class="rounded-lg border border-amber/15 bg-black/20 p-4">
          <p class="font-classical text-base font-black text-mist">未確定メモ</p>
          <p class="mt-2 text-sm leading-7 text-muted">
            設備の細部は公演や当日案内で変わる場合があります。ここでは未確定項目を小さく残し、当日の動き方を優先して案内します。
          </p>
          <p class="mt-2 text-xs font-bold leading-6 text-muted">
            確認中: {unknownRows.slice(0, 4).join('、')}{unknownRows.length > 4 ? ` ほか${unknownRows.length - 4}件` : ''}
          </p>
        </section>
      )}
    </div>

    <aside class="space-y-5 lg:sticky lg:top-24">
      <div class="gothic-card rounded-xl p-5">
        <p class="font-classical text-lg font-black text-mist">公式・検索リンク</p>
        <div class="mt-4 grid gap-3">
          {venue.officialUrl ? (
            <a class="gothic-button focus-ring inline-flex min-h-11 items-center justify-center rounded-md px-4 text-sm font-black" href={venue.officialUrl} target="_blank" rel="noopener noreferrer">会場公式を見る</a>
          ) : (
            <p class="rounded-md border border-amber/20 bg-black/25 p-3 text-sm leading-6 text-muted">公式URLは確認中です。会場名で検索し、最新情報を確認してください。</p>
          )}
          {(venue.ticketSearchLinks ?? []).map((link) => (
            <a class="gothic-button-secondary focus-ring inline-flex min-h-11 items-center justify-center rounded-md px-4 text-sm font-black" href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </div>
      </div>

      <div class="gothic-card rounded-xl p-5">
        <p class="font-classical text-lg font-black text-mist">公演情報は公式で確認</p>
        <p class="mt-3 text-sm leading-7 text-muted">
          このページでは公演名、出演者、日程、チケット状況を掲載しません。最新の公演情報は必ず公式サイト、チケットサイト、会場公式スケジュールで確認してください。
        </p>
      </div>
    </aside>
  </section>
  <RelatedGuideLinks title="この会場へ行く前にあわせて確認" />
</Layout>
