---
import SeoGuidePage from '@components/SeoGuidePage.astro';

const sections = [
  {
    title: '小規模会場のロッカーは「あるか」だけで判断しない',
    lead: 'ロッカーありでも、数が少ない、開場後だけ、サイズが小さい、終演後に取り出しが混むなど、当日の動き方は変わります。',
    points: [
      'ロッカー数が少ない会場では、開場前に埋まる前提で駅ロッカーも候補にする。',
      '開場後ロッカーの場合、良番の日は荷物処理で入場後の動きが遅れることがある。',
      'キャリーケースは会場ロッカーに入らないことが多い。大型荷物は駅、ホテル、荷物預かりを優先する。',
    ],
  },
  {
    title: 'クロークは便利だが、公演ごとの運用を見る',
    lead: 'クロークは大きな袋にまとめて預ける形式が多く、料金、受付時間、返却タイミングが公演ごとに変わる場合があります。',
    points: [
      'クロークありの会場でも、受付開始が開場前か入場後かで動き方が変わる。',
      'キャリー対応の有無は会場や公演で差がある。大型荷物は預けられない前提でも考えておく。',
      '終演後にクローク返却と物販が重なると時間を使う。終電が近い日は回収順を先に決める。',
    ],
  },
  {
    title: '駅ロッカーを先に使うべき条件',
    lead: '小規模会場では会場前で荷物を広げる余裕がないこともあります。駅に着いた時点で身軽にすると、その後の判断が楽になります。',
    points: [
      'キャリーあり、物販多め、雨、良番、終電が近い日は駅ロッカー先行がおすすめ。',
      '休日の大きな駅はロッカーが埋まりやすいので、サブ駅やホテル預けも候補にする。',
      'ロッカー代の小銭や決済方法は場所で違うため、現金と交通系ICを両方用意する。',
    ],
  },
  {
    title: 'ロッカーもクロークも読めない日の安全策',
    lead: '会場設備が確認中でも、当日の動き方は決められます。迷ったら「小さくして入る」「大きいものは駅で処理」が基本です。',
    points: [
      '会場に入るバッグは、体の前で管理できるサイズにする。',
      'リュックは背負ったままにせず、混む場面では前に持つ。',
      '荷物が増える予定なら、先に預け先を確保してから物販へ向かう。',
    ],
  },
];
---

<SeoGuidePage
  title="小規模会場のロッカー・クローク完全ガイド｜推し活遠征ナビ"
  description="小規模ライブハウスやイベント会場で迷いやすいロッカー、クローク、駅ロッカー、キャリーケース、物販後の荷物対策を整理。推し活現場当日の動き方を確認できます。"
  pageTitle="小規模会場のロッカー・クローク完全ガイド"
  eyebrow="Locker and Cloak"
  lead="小規模会場で困りやすいのは、現場の内容ではなく荷物の置き場です。ロッカー、クローク、駅ロッカーの使い分けを当日目線で整理します。"
  sections={sections}
/>
