---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Checklist from '@components/Checklist.astro';
import MonetizationBox from '@components/MonetizationBox.astro';
import NoticeBox from '@components/NoticeBox.astro';
import RelatedGuideLinks from '@components/RelatedGuideLinks.astro';
import SectionTitle from '@components/SectionTitle.astro';

const title = '持ち物チェックリスト｜推し活遠征ナビ';
const description = '推し活現場の持ち物チェックリスト。チケット、身分証、現金、交通系IC、モバイルバッテリー、タオル、雨具、物販用バッグ、常備薬などをブラウザ上で確認できます。';
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'ガイド', href: '/guides/beginner' }, { label: '持ち物チェックリスト' }]} />
  <section class="container-navi py-8">
    <div class="max-w-3xl">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan">Belongings</p>
      <h1 class="mt-3 text-3xl font-black leading-tight text-white md:text-5xl">持ち物チェックリスト</h1>
      <p class="mt-4 text-base leading-8 text-muted md:text-lg">
        チェック状態はこのブラウザにだけ保存されます。ライブ前日と出発前にもう一度確認すると忘れ物を減らせます。
      </p>
    </div>
    <div class="mt-8">
      <NoticeBox title="会場ごとに変わるもの" tone="warning">
        <p>ドリンク代の金額、支払い方法、ロッカー・クロークの有無、身分証確認は公演ごとに変わることがあります。公式案内を必ず確認してください。</p>
      </NoticeBox>
    </div>
  </section>
  <section class="container-navi py-8">
    <Checklist />
  </section>
  <section class="container-navi py-8">
    <MonetizationBox
      title="持ち物を増やしすぎないための準備枠"
      lead="物販・雨・終演後移動がある日は、荷物を減らしつつ必要なものだけ持つのがおすすめです。"
    />
  </section>
  <section class="container-navi py-8">
    <SectionTitle title="荷物を軽くする考え方" />
    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-line bg-panel p-5">
        <p class="font-black text-white">会場内は最小限</p>
        <p class="mt-2 text-sm leading-7 text-muted">チケット、スマホ、現金、IC、身分証、タオルくらいに絞ると動きやすくなります。</p>
      </div>
      <div class="rounded-lg border border-line bg-panel p-5">
        <p class="font-black text-white">物販後を想定</p>
        <p class="mt-2 text-sm leading-7 text-muted">買った後に袋が必要になります。折りたためるバッグを入れておくと安心です。</p>
      </div>
      <div class="rounded-lg border border-line bg-panel p-5">
        <p class="font-black text-white">雨の日は袋が強い</p>
        <p class="mt-2 text-sm leading-7 text-muted">濡れた傘、タオル、着替えを分けられるビニール袋があると帰りが楽です。</p>
      </div>
    </div>
  </section>
  <RelatedGuideLinks title="持ち物と一緒に確認したいガイド" />
</Layout>
