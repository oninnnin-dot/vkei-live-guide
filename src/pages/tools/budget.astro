---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import BudgetCalculator from '@components/BudgetCalculator.astro';
import NoticeBox from '@components/NoticeBox.astro';
import SectionTitle from '@components/SectionTitle.astro';

const title = '遠征費シミュレーター｜V系ライブ遠征ナビ';
const description = 'V系ライブ遠征費をブラウザ内で計算。チケット代、交通費、ホテル代、物販予算、食費、ドリンク代、ロッカー代、その他を入力して合計を確認できます。';
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'ツール', href: '/tools/budget' }, { label: '遠征費シミュレーター' }]} />
  <section class="container-navi py-8">
    <div class="max-w-3xl">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan">Tool</p>
      <div class="mt-3 text-3xl font-black leading-tight text-white md:text-5xl" role="heading" aria-level="1">遠征費シミュレーター</div>
      <p class="mt-4 text-base leading-8 text-muted md:text-lg">
        チケット代だけでなく、交通費、ホテル代、物販、ロッカー代まで入れると、日帰り向きか泊まり向きかを判断しやすくなります。
      </p>
    </div>
    <div class="mt-8">
      <NoticeBox title="外部APIなし" tone="success">
        <p>このツールはブラウザ内計算のみで動きます。入力内容は外部送信せず、DBにも保存しません。</p>
      </NoticeBox>
    </div>
  </section>
  <section class="container-navi py-8">
    <BudgetCalculator />
  </section>
  <section class="container-navi py-8">
    <SectionTitle title="遠征費で見落としやすいもの" />
    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-line bg-panel p-5">
        <p class="font-black text-white">チケット手数料</p>
        <p class="mt-2 text-sm leading-7 text-muted">先行手数料、発券手数料、システム利用料が別にかかる場合があります。</p>
      </div>
      <div class="rounded-lg border border-line bg-panel p-5">
        <p class="font-black text-white">終演後の移動</p>
        <p class="mt-2 text-sm leading-7 text-muted">終電を逃した場合のタクシー代や延泊費も、遠征ではリスクとして見ておくと安心です。</p>
      </div>
      <div class="rounded-lg border border-line bg-panel p-5">
        <p class="font-black text-white">物販の上限</p>
        <p class="mt-2 text-sm leading-7 text-muted">ランダムグッズやチェキで予算が膨らみやすいので、上限を決めると帰りの余裕が残ります。</p>
      </div>
    </div>
  </section>
</Layout>
