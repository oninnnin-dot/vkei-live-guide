---
import Layout from '@layouts/Layout.astro';
import BaggageDiagnosis from '@components/BaggageDiagnosis.astro';
import Hero from '@components/Hero.astro';
import LinkCard from '@components/LinkCard.astro';
import MonetizationBox from '@components/MonetizationBox.astro';
import NoticeBox from '@components/NoticeBox.astro';
import SectionTitle from '@components/SectionTitle.astro';
import VenueCard from '@components/VenueCard.astro';
import venues from '@data/venues.json';
import type { Venue } from '@/types';

const title = '推し活遠征ナビ｜小規模会場のロッカー・荷物・待機場所ガイド';
const description = '推し活の遠征や現場準備で迷いやすいロッカー、クローク、荷物、待機場所、雨の日、終演後の動き方をまとめた実用ガイド。公演・イベント情報は公式で確認し、当日の不安をここで減らすサイトです。';

const prioritySlugs = [
  'ikebukuro-edge',
  'ikebukuro-blackhole',
  'sugamo-shishio',
  'shibuya-rex',
  'takadanobaba-club-phase',
  'wildside-tokyo',
  'higashi-koenji-20000v',
  'music-lab-hamashobo',
  'yokohama-baysis',
];

const priorityVenues = (venues as Venue[])
  .filter((venue) => prioritySlugs.includes(venue.slug) && venue.status === 'active' && venue.showInVenueList && !venue.archiveOnly)
  .sort((a, b) => prioritySlugs.indexOf(a.slug) - prioritySlugs.indexOf(b.slug));

const mainLinks = [
  {
    title: '今週末のライブ・イベントを探す',
    description: 'チケットサイト、公式スケジュール、会場公式への入口をまとめています。',
    href: '/weekend',
    cta: '公式リンクを見る',
  },
  {
    title: '会場攻略を見る',
    description: 'ロッカー、クローク、待機場所、雨の日、終演後の帰り方を会場ごとに確認できます。',
    href: '/venues',
    cta: '会場一覧へ',
  },
  {
    title: '初参戦ガイドを見る',
    description: '整理番号、荷物、ドリンク代、立ち位置、終演後の動き方を小規模会場向けに整理しています。',
    href: '/guides/small-venue',
    cta: '当日の流れを確認',
  },
  {
    title: '持ち物チェックリスト',
    description: 'チケット、身分証、モバイルバッテリー、雨具、物販用バッグなどをブラウザ上でチェックできます。',
    href: '/v-kei-live-belongings/',
    cta: 'チェックする',
  },
  {
    title: '遠征費シミュレーター',
    description: 'チケット代、交通費、ホテル代、物販予算などを入れて、遠征費の合計をその場で計算できます。',
    href: '/tools/budget',
    cta: '計算する',
  },
  {
    title: 'ライブハウス豆知識',
    description: 'ロッカーとクロークの違い、駅ロッカーを使う判断、地下会場や終演後の注意をまとめています。',
    href: '/guides/livehouse-tips',
    cta: '豆知識を見る',
  },
];

const seoLinks = [
  {
    title: '推し活現場の持ち物チェックリスト',
    description: '会場に持ち込むもの、駅やホテルに預けるもの、物販・特典会後に増える荷物を分けて確認できます。',
    href: '/v-kei-live-belongings/',
    cta: '持ち物を確認',
  },
  {
    title: '小規模会場のロッカー・クローク完全ガイド',
    description: 'ロッカー、クローク、駅ロッカー、キャリーケースの判断を推し活現場向けに整理しています。',
    href: '/small-livehouse-locker-cloak/',
    cta: '荷物対策を見る',
  },
  {
    title: 'ライブ前に駅ロッカーを使うべき場面',
    description: 'キャリーあり、良番、物販、雨の日など、駅ロッカー先行が強い条件を確認できます。',
    href: '/livehouse-station-locker/',
    cta: '駅ロッカー判断へ',
  },
  {
    title: '初参戦ガイド',
    description: '整理番号、入場、立ち位置、終演後の流れを初めての人向けにまとめています。',
    href: '/vkei-first-live-guide/',
    cta: '初参戦の流れへ',
  },
  {
    title: '推し活遠征費の目安',
    description: '交通費、ホテル代、物販、ロッカー代、終演後の移動費まで含めて考えます。',
    href: '/vkei-live-trip-cost/',
    cta: '費用の目安へ',
  },
  {
    title: '雨の日の現場対策',
    description: '傘、濡れた荷物、待機場所、終演後の移動を雨の日向けに整理します。',
    href: '/vkei-live-rainy-day/',
    cta: '雨の日対策へ',
  },
  {
    title: '終演後の帰り方・終電・宿泊判断',
    description: 'クローク返却、物販、駅までの移動、終電、宿泊判断を先に決めるためのガイドです。',
    href: '/vkei-live-after-show/',
    cta: '帰り方を見る',
  },
];
---

<Layout title={title} description={description}>
  <Hero
    title="推し活遠征ナビ"
    catchcopy="現場情報は公式で探す。遠征と会場準備の不安はここで減らす。"
    description="ライブ、アイドル現場、アニメ・漫画系イベント、舞台、リリースイベントへ行く前に確認したい、会場周辺情報、ロッカー、クローク、待機場所、コンビニ、終演後の帰り方、初参戦の不安、遠征費をまとめる実用ナビです。"
    actions={[
      { href: '/weekend', label: '今週末のライブ・イベントを探す', primary: true },
      { href: '/venues', label: '会場攻略を見る' },
      { href: '/guides/small-venue', label: '初参戦ガイド' },
      { href: '/tools/budget', label: '遠征費シミュレーター' },
    ]}
  />

  <BaggageDiagnosis />

  <section class="container-navi py-8">
    <MonetizationBox />
  </section>

  <section class="container-navi py-10">
    <NoticeBox title="このサイトの役割" tone="warning">
      <p>
        公演・イベント情報、チケット情報は必ず公式サイト、チケットサイト、会場公式スケジュールで確認してください。当サイトは、会場周辺情報、荷物対策、ロッカー・クローク、終演後の帰り方を補助するサイトです。
      </p>
    </NoticeBox>
  </section>

  <section class="container-navi py-8">
    <SectionTitle
      eyebrow="Practical guides"
      title="検索前にも、会場へ向かう前にも読める実用記事"
      lead="会場名がまだ決まっていない段階でも、荷物、ロッカー、雨、遠征費、終演後の動き方を先に確認できます。"
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {seoLinks.map((link) => <LinkCard {...link} />)}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle
      eyebrow="Start"
      title="現場が決まる前も、決まった後も使う"
      lead="チケット探しの入口から、初参戦の流れ、会場別の動き方、当日の持ち物までスマホで確認しやすい導線にしています。"
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {mainLinks.map((link) => <LinkCard {...link} />)}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle
      eyebrow="Venues"
      title="小規模現場で確認候補になりやすい会場"
      lead="ライブハウスやイベントスペースなど、荷物・待機場所・帰り方の確認が必要になりやすい現役会場を中心に表示しています。閉館済み会場はおすすめ枠に出しません。"
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {priorityVenues.map((venue) => <VenueCard venue={venue} compact />)}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle
      eyebrow="No scraping"
      title="公演情報は公式へ案内する"
      lead="MVPではスクレイピング、外部DB、外部API、X API、無断画像利用を使わず、MarkdownとJSONで静的に更新できる構成にしています。"
    />
    <div class="grid gap-4 md:grid-cols-3">
      <div class="gothic-card rounded-xl p-5">
        <p class="font-classical font-black text-mist">公式確認を前提</p>
        <p class="mt-2 text-sm leading-7 text-muted">公演日、出演者、チケット販売状況は公式ページで確認する導線にしています。</p>
      </div>
      <div class="gothic-card rounded-xl p-5">
        <p class="font-classical font-black text-mist">現場前後の不安に集中</p>
        <p class="mt-2 text-sm leading-7 text-muted">ロッカー、クローク、待機場所、雨、夜の帰り道、一人参戦の動き方を整理します。</p>
      </div>
      <div class="gothic-card rounded-xl p-5">
        <p class="font-classical font-black text-mist">静的で壊れにくい</p>
        <p class="mt-2 text-sm leading-7 text-muted">Astro、Markdown、JSONだけで更新しやすく、Cloudflare Pagesで0円運用しやすい構成です。</p>
      </div>
    </div>
  </section>
</Layout>
