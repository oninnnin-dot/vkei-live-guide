---
import Layout from '@layouts/Layout.astro';
import BaggageDiagnosis from '@components/BaggageDiagnosis.astro';
import Hero from '@components/Hero.astro';
import LinkCard from '@components/LinkCard.astro';
import MonetizationBox from '@components/MonetizationBox.astro';
import SectionTitle from '@components/SectionTitle.astro';
import VenueCard from '@components/VenueCard.astro';
import venues from '@data/venues.json';
import type { Venue } from '@/types';
import { sortVenuesForTopPage } from '@/utils/venueSort';

const title = '推し活遠征ナビ｜会場名の行き方・コンビニ・待機場所・終演後の帰り方ガイド';
const description = '小規模ライブハウスや推し活現場へ行く前に確認したい、会場名の行き方、最寄出口、ロッカー、クローク、近くのコンビニ、待機場所、雨の日、終演後の帰り方、一人参戦の不安をまとめる実用ナビです。';

const priorityVenues = sortVenuesForTopPage(venues as Venue[]);

const mainLinks = [
  {
    title: '会場名で探す',
    description: '会場名、駅名、エリア、困りごとから、当日の動き方が分かる会場ページを探せます。',
    href: '/venues',
    cta: '会場一覧へ',
  },
  {
    title: 'エリアで探す',
    description: '池袋、渋谷、新宿、下北沢など、現場が多いエリアから会場を確認できます。',
    href: '/areas',
    cta: 'エリア一覧へ',
  },
  {
    title: '今週末のライブ・イベントを探す',
    description: 'チケットサイト、公式スケジュール、会場公式への入口をまとめています。',
    href: '/weekend',
    cta: '公式リンクを見る',
  },
  {
    title: '初参戦ガイドを見る',
    description: '整理番号、荷物、ドリンク代、立ち位置、終演後の動き方を小規模会場向けに整理しています。',
    href: '/guides/small-venue',
    cta: '当日の流れを確認',
  },
  {
    title: '持ち物チェックリスト',
    description: 'チケット、身分証、モバイルバッテリー、雨具、物販用バッグなどをブラウザ上でチェックできます。',
    href: '/v-kei-live-belongings/',
    cta: 'チェックする',
  },
  {
    title: '遠征費シミュレーター',
    description: 'チケット代、交通費、ホテル代、物販予算などを入れて、遠征費の合計をその場で計算できます。',
    href: '/tools/budget',
    cta: '計算する',
  },
  {
    title: 'ライブハウス豆知識',
    description: 'ロッカーとクロークの違い、駅ロッカーを使う判断、地下会場や終演後の注意をまとめています。',
    href: '/guides/livehouse-tips',
    cta: '豆知識を見る',
  },
];

const worryTags = [
  { label: 'ロッカー', href: '/venues?q=ロッカー' },
  { label: 'コンビニ', href: '/venues?q=コンビニ' },
  { label: '待機場所', href: '/venues?q=待機' },
  { label: '雨の日', href: '/venues?q=雨' },
  { label: '終演後', href: '/venues?q=終演後' },
  { label: '一人参戦', href: '/venues?q=一人参戦' },
  { label: 'キャリーケース', href: '/venues?q=キャリー' },
  { label: '良番', href: '/venues?q=良番' },
  { label: '物販', href: '/venues?q=物販' },
];

const seoLinks = [
  {
    title: '推し活現場の持ち物チェックリスト',
    description: '会場に持ち込むもの、駅やホテルに預けるもの、物販・特典会後に増える荷物を分けて確認できます。',
    href: '/v-kei-live-belongings/',
    cta: '持ち物を確認',
  },
  {
    title: '小規模会場のロッカー・クローク完全ガイド',
    description: 'ロッカー、クローク、駅ロッカー、キャリーケースの判断を推し活現場向けに整理しています。',
    href: '/small-livehouse-locker-cloak/',
    cta: '荷物対策を見る',
  },
  {
    title: 'ライブ前に駅ロッカーを使うべき場面',
    description: 'キャリーあり、良番、物販、雨の日など、駅ロッカー先行が強い条件を確認できます。',
    href: '/livehouse-station-locker/',
    cta: '駅ロッカー判断へ',
  },
  {
    title: '初参戦ガイド',
    description: '整理番号、入場、立ち位置、終演後の流れを初めての人向けにまとめています。',
    href: '/vkei-first-live-guide/',
    cta: '初参戦の流れへ',
  },
  {
    title: '推し活遠征費の目安',
    description: '交通費、ホテル代、物販、ロッカー代、終演後の移動費まで含めて考えます。',
    href: '/vkei-live-trip-cost/',
    cta: '費用の目安へ',
  },
  {
    title: '雨の日の現場対策',
    description: '傘、濡れた荷物、待機場所、終演後の移動を雨の日向けに整理します。',
    href: '/vkei-live-rainy-day/',
    cta: '雨の日対策へ',
  },
  {
    title: '終演後の帰り方・終電・宿泊判断',
    description: 'クローク返却、物販、駅までの移動、終電、宿泊判断を先に決めるためのガイドです。',
    href: '/vkei-live-after-show/',
    cta: '帰り方を見る',
  },
];
---

<Layout title={title} description={description}>
  <Hero
    title="推し活遠征ナビ"
    catchcopy="会場名の行き方、コンビニ、待機場所、終演後の帰り方を出発前に確認する。"
    description="小規模ライブハウスや推し活現場へ行く前に、荷物・ロッカー・最寄出口・近いコンビニ・待機場所・終演後の帰り方を整理します。公演情報は公式で確認し、このサイトでは会場まわりの不安を減らします。"
    actions={[
      { href: '/venues', label: '会場名で探す', primary: true },
      { href: '/areas', label: 'エリアで探す' },
      { href: '/guides/small-venue', label: '初参戦ガイドを見る' },
      { href: '/tools/budget', label: '遠征費を計算する' },
    ]}
  />

  <section class="container-navi py-6">
    <div class="grid gap-4 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="rounded-lg border border-amber/20 bg-black/25 p-4">
        <p class="gothic-label">Search</p>
        <h2 class="font-classical mt-2 text-xl font-black text-mist">会場名・エリア・困りごとで探す</h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <a class="gothic-button focus-ring inline-flex min-h-11 items-center justify-center rounded-md px-4 text-sm font-black" href="/venues">会場名で探す</a>
          <a class="gothic-button-secondary focus-ring inline-flex min-h-11 items-center justify-center rounded-md px-4 text-sm font-black" href="/areas">エリアで探す</a>
        </div>
      </div>
      <div class="rounded-lg border border-amber/20 bg-black/25 p-4">
        <p class="gothic-label">Trouble</p>
        <h2 class="font-classical mt-2 text-xl font-black text-mist">困りごとで探す</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {worryTags.map((tag) => (
            <a class="gothic-chip rounded-md px-3 py-1.5 text-xs font-black hover:border-amber/70" href={tag.href}>{tag.label}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <BaggageDiagnosis />

  <section class="container-navi py-8">
    <SectionTitle
      eyebrow="Practical guides"
      title="検索前にも、会場へ向かう前にも読める実用記事"
      lead="会場名がまだ決まっていない段階でも、荷物、ロッカー、雨、遠征費、終演後の動き方を先に確認できます。"
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {seoLinks.map((link) => <LinkCard {...link} />)}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle
      eyebrow="Start"
      title="現場が決まる前も、決まった後も使う"
      lead="チケット探しの入口から、初参戦の流れ、会場別の動き方、当日の持ち物までスマホで確認しやすい導線にしています。"
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {mainLinks.map((link) => <LinkCard {...link} />)}
    </div>
  </section>

  <section class="container-navi py-8">
    <SectionTitle
      eyebrow="Venues"
      title="まず高密度にした東京10会場"
      lead="会場数よりも、最寄出口、コンビニ、待機場所、雨の日、終演後導線まで具体的に確認できる東京の主要小規模会場を優先表示しています。"
    />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {priorityVenues.map((venue) => <VenueCard venue={venue} compact />)}
    </div>
  </section>

  <section class="container-navi py-8">
    <MonetizationBox />
  </section>

  <section class="container-navi py-4">
    <div class="rounded-lg border border-amber/15 bg-black/20 p-4">
      <h2 class="font-classical text-lg font-black text-mist">このサイトについて</h2>
      <div class="mt-2 space-y-2 text-sm leading-7 text-muted">
        <p>公演日・出演者・チケット状況は、必ず公式サイトや主催者案内で確認してください。</p>
        <p>このサイトでは、ロッカー、クローク、待機場所、雨の日、終演後の帰り方、一人参戦の不安など、会場へ行く前後に困りやすい情報を整理しています。</p>
      </div>
    </div>
  </section>
</Layout>
