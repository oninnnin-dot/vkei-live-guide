---
import SeoGuidePage from '@components/SeoGuidePage.astro';

const sections = [
  {
    title: '遠征費はチケット代だけで見ない',
    lead: '推し活遠征では、交通費、宿泊、ロッカー、食費、物販、終演後の移動費が重なります。',
    points: [
      '最低限の計算は、チケット代、交通費、宿泊費、物販予算、食費、ドリンク代、ロッカー代で見る。',
      '夜行バスや新幹線を使う日は、駅ロッカー、大型荷物預かり、シャワー、早朝の待機場所も費用に入れる。',
      '終電を逃した場合のタクシー代や延泊費を、緊急予算として少し残す。',
    ],
  },
  {
    title: '日帰りと泊まりの判断',
    lead: '終演時間だけでなく、クローク返却、物販、駅までの移動を含めて考えます。',
    points: [
      '終電まで1時間未満なら、物販やクローク返却をどうするか先に決める。',
      '会場から主要駅まで乗り換えが多い場合、泊まりの方が安心なことがある。',
      '遠征先で初めての会場なら、夜道で迷う時間も見込んでおく。',
    ],
  },
  {
    title: '物販予算を決める',
    lead: 'ランダムグッズやチェキは予算が膨らみやすいため、上限を決めると帰りの余裕を残せます。',
    points: [
      '現金払いの可能性があるため、使ってよい金額と残す金額を分ける。',
      '物販後に荷物が増えるなら、ロッカー代やサブバッグも小さな費用として見る。',
      '遠征では帰りの交通費と食費を先に確保してから物販に回す。',
    ],
  },
  {
    title: '節約より優先したい安全費',
    lead: '安く済ませることより、終演後に詰まないことを優先します。',
    points: [
      '雨の日や深夜移動では、少し高くても駅近ホテルや乗り換えの少ないルートが安心。',
      'キャリーがある日は大型ロッカー代やホテル預けを前提にする。',
      '帰りが遅くなる日は、タクシーや延泊の保険予算を残す。',
    ],
  },
];
---

<SeoGuidePage
  title="推し活遠征費の目安｜交通費・ホテル・物販・ロッカー代"
  description="推し活遠征で見落としやすい交通費、ホテル代、物販予算、食費、ドリンク代、ロッカー代、終演後の移動費を整理します。"
  pageTitle="推し活遠征費の目安"
  eyebrow="Trip Cost"
  lead="遠征費はチケット代だけでは判断できません。終演後の移動、宿泊、荷物預け、物販まで含めて、無理のない予算を作ります。"
  sections={sections}
/>
