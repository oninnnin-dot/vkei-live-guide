---
import Layout from '@layouts/Layout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import SectionTitle from '@components/SectionTitle.astro';
import { areaGuides } from '@/data/areaGuides';
import venues from '@data/venues.json';
import type { Venue } from '@/types';

const title = '推し活遠征エリア攻略一覧｜ロッカー・荷物・待機場所';
const description = '池袋、渋谷、高田馬場、新宿、下北沢、横浜、高円寺、巣鴨など、推し活遠征で迷いやすい荷物、ロッカー、待機場所、終演後の動き方をエリア別に整理します。';

const allVenues = (venues as Venue[]).filter((venue) => venue.status !== 'closed' && venue.showInVenueList && !venue.archiveOnly);
const countVenues = (aliases: string[]) =>
  allVenues.filter((venue) => aliases.some((area) => venue.area?.includes(area) || venue.areaGroup?.includes(area.toLowerCase()))).length;
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'エリア攻略' }]} />

  <section class="container-navi py-8">
    <div class="gothic-panel rounded-xl p-5 md:p-8">
      <p class="gothic-label">Area Guide</p>
      <h1 class="font-classical mt-4 text-3xl font-black leading-tight text-mist md:text-5xl">推し活遠征エリア攻略</h1>
      <p class="mt-4 max-w-3xl text-sm leading-8 text-muted md:text-base">
        公演情報ではなく、エリアごとの荷物・ロッカー・待機場所・雨の日・終演後の帰り方を整理する入口です。
      </p>
    </div>
  </section>

  <section class="container-navi pb-12">
    <SectionTitle eyebrow="Areas" title="エリア一覧" lead="まずは主要エリアの会場数と動き方の傾向を確認できます。" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {areaGuides.map((area) => (
        <article class="area-card rounded-xl p-5">
          <p class="gothic-label">{countVenues(area.aliases)} venues</p>
          <h2 class="font-classical mt-3 text-2xl font-black text-mist">{area.name}</h2>
          <p class="mt-3 text-sm leading-7 text-muted">{area.overview}</p>
          <a class="gothic-button focus-ring mt-5 inline-flex min-h-11 items-center justify-center rounded-md px-4 text-sm font-black" href={`/areas/${area.slug}/`}>
            このエリアを見る
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
