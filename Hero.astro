---
interface Action {
  href: string;
  label: string;
  primary?: boolean;
}

interface Props {
  title: string;
  catchcopy: string;
  description: string;
  actions?: Action[];
}

const { title, catchcopy, description, actions = [] } = Astro.props;
---

<section class="relative overflow-hidden border-b border-line bg-black/25">
  <div class="container-navi grid gap-8 py-10 md:grid-cols-[1fr_0.72fr] md:py-16">
    <div class="flex flex-col justify-center">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-cyan">Visual Kei Live Trip Guide</p>
      <h1 class="mt-4 text-4xl font-black leading-tight text-white md:text-6xl">{title}</h1>
      <p class="mt-5 text-xl font-black leading-relaxed text-mist md:text-2xl">{catchcopy}</p>
      <p class="mt-4 max-w-2xl text-base leading-8 text-muted">{description}</p>
      {actions.length > 0 && (
        <div class="mt-7 grid gap-3 sm:grid-cols-2">
          {
            actions.map((action) => (
              <a
                class={`focus-ring inline-flex min-h-12 items-center justify-center rounded-md px-5 py-3 text-center text-sm font-black transition ${
                  action.primary
                    ? 'bg-violet text-white hover:bg-magenta'
                    : 'border border-line bg-panel text-mist hover:border-violet/70 hover:bg-white/5'
                }`}
                href={action.href}
              >
                {action.label}
              </a>
            ))
          }
        </div>
      )}
    </div>
    <div class="min-h-72 rounded-lg border border-line bg-panel p-5 shadow-glow">
      <div class="flex h-full flex-col justify-between gap-5">
        <div class="grid grid-cols-5 gap-2" aria-hidden="true">
          <span class="h-32 rounded-sm bg-violet/80"></span>
          <span class="mt-8 h-24 rounded-sm bg-magenta/70"></span>
          <span class="h-40 rounded-sm bg-white/85"></span>
          <span class="mt-12 h-20 rounded-sm bg-cyan/70"></span>
          <span class="mt-4 h-28 rounded-sm bg-amber/80"></span>
        </div>
        <div class="rounded-md border border-line bg-black/30 p-4">
          <p class="text-sm font-black text-white">遠征前チェック</p>
          <ul class="mt-3 space-y-2 text-sm text-muted">
            <li>公式チケット情報を確認</li>
            <li>会場・駅・ロッカーを確認</li>
            <li>終電と宿泊ラインを確認</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
