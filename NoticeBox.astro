---
interface Props {
  title?: string;
  tone?: 'default' | 'warning' | 'success';
}

const { title = '確認メモ', tone = 'default' } = Astro.props;
const toneClass = {
  default: 'border-violet/45 bg-violet/10',
  warning: 'border-amber/55 bg-amber/10',
  success: 'border-cyan/55 bg-cyan/10',
}[tone];
---

<aside class={`rounded-lg border ${toneClass} p-4 text-sm leading-7 text-mist`}>
  <p class="mb-2 font-black text-white">{title}</p>
  <slot />
</aside>
